---
import GrilleOffres from "./components/GrilleOffres.astro";
import GrilleOffresWeb from "./components/GrilleOffresWeb.astro";
import GrilleOffresMetier from "./components/GrilleOffresMetier.astro";
import GrilleOffresApp from "./components/GrilleOffresApp.astro";
import GrilleOffresIot from "./components/GrilleOffresIot.astro";
import GrilleOffresAi from "./components/GrilleOffresAi.astro";

import GrilleIntro from "../Hero/components/GrilleIntro.astro";
import Revealtext from "../../../animations/RevealText.astro";
import Typper from "../../../animations/tipper/Typper.astro";

// import PolygoneFlipProg from "../commun/polygones/PolygoneFlipProg.astro";
import digitalArrow from "../../../assets/images/digital-arrow.svg";
---

<div class="oka-appWrap -full">
  <!-- Contenu après le pin : visible une fois que #offres se dépine -->
  <section class="sok-section oka-show--md">
    <div class="flex-grid">
      <div class="col col-8"></div>
      <div class="col col-8">
        <GrilleIntro
          cols="4"
          rows="1"
          dataAttrs={{ appearGroup: "", delay: "2.5" }}
        />
        <div class="oka-spacer -xxl" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <section class="sok-offres" id="offres">
    <div class="sok-offres__intro flex-grid">
      <div class="col col-1"></div>
      <div class="col col-7">
          <div class="oka-spacer -lg" aria-hidden="true"></div>
          <Revealtext>     
            <div class="oka-data -xs">Titre seo sur les offres</div>     
            <h2 class="oka-h -xl -secondary">Nous intervenons sur le développement de vos produits, vos services, vos process.</h2>
          </Revealtext>
          <div class="oka-spacer -lg" aria-hidden="true" ></div>
      </div>
    </div>

    <!-- none  -->
    <div class="sok-offre -background flex-grid">
      <div class="col col-4"></div>

      <div class="col col-4">
        <div class="sok-offre__detail">
          <p></p>
        </div>
      </div>

      <div class="col col-8">
        <GrilleOffres />
      </div>
    </div>

    <!-- WEB  -->
    <div class="sok-offre flex-grid">
      <div class="col col-1 oka-show--md">
        <div class="sok-offre__indic -web">
          <img
            class="sok-arrow"
            src={digitalArrow.src}
            alt="flèche"
            aria-hidden="true"
          />
          <span class="sok-num oka-data -xs -crop">01</span>
        </div>
      </div>

      <div class="sok-offre__colTitle col col-4 col--md-3">
        <div
          class="sok-offre__item -web"
          data-offre="web"
          data-offset-lg="top 30%"
        >
          <h3 class="oka-h -md">Solutions Web</h3>
        </div>
      </div>

      <div class="sok-offre__detail col col-4 col--md-3">
        <p>
          <Typper
            id="typper-web-1"
            manual
            text="Elle répond à différents besoins : gestion interne (ERP, CRM, outils collaboratifs), services en ligne (réservation, e-commerce, espace client) et automatisation de processus."
          />
        </p>
        <p>
          <Typper
            id="typper-web-2"
            manual
            text="Flexible et accessible depuis tout appareil connecté, elle s'adapte à tous les secteurs. Un levier efficace pour améliorer la productivité, l'expérience utilisateur et soutenir votre croissance."
          />
        </p>
      </div>

      <div class="col col-1 oka-show--md"></div>

      <div class="col col-8">
        <GrilleOffresWeb />
      </div>
    </div>

    <!-- METIER  -->

    <div class="sok-offre flex-grid">
      <div class="col col-1 oka-show--md">
        <div class="sok-offre__indic -metier">
          <img
            class="sok-arrow"
            src={digitalArrow.src}
            alt="flèche"
            aria-hidden="true"
          />
          <span class="sok-num oka-data -xs -crop">02</span>
        </div>
      </div>

      <div class="sok-offre__colTitle col col-4 col--md-3">
        <div
          class="sok-offre__item -metier"
          data-offre="metier"
          data-offset-lg="top 30%"
        >
          <h3 class="oka-h -md">Logiciels Métiers</h3>
        </div>
      </div>

      <div class="sok-offre__detail col col-4 col--md-3">
        <p>
          <Typper
            id="typper-metier-1"
            manual
            text="Lorem ipsum des logiciels métiers dolor sit amet consectetur adipisicing elit. Adipisci maiores animi mollitia labore, nulla veniam voluptates consequuntur recusandae. Doloribus molestiae, fuga facere nobis accusantium dignissimos ut architecto suscipit quo laborum."
          />
        </p>
      </div>

      <div class="col col-1 oka-show--md"></div>

      <div class="col col-8">
        <GrilleOffresMetier />
      </div>
    </div>

    <!-- APP -->

    <div class="sok-offre flex-grid">
      <div class="col col-1 oka-show--md">
        <div class="sok-offre__indic -app">
          <img
            class="sok-arrow"
            src={digitalArrow.src}
            alt="flèche"
            aria-hidden="true"
          />
          <span class="sok-num oka-data -xs -crop">03</span>
        </div>
      </div>

      <div class="sok-offre__colTitle col col-3">
        <div
          class="sok-offre__item -app"
          data-offre="app"
          data-offset-lg="top 30%"
        >
          <h3 class="oka-h -md">Applications mobiles</h3>
        </div>
      </div>

      <div class="sok-offre__detail col col-3">
        <p>
          <Typper
            id="typper-app-1"
            manual
            text="Lorem ipsum des applications mobiles dolor sit amet consectetur adipisicing elit. Adipisci maiores animi mollitia labore, nulla veniam voluptates consequuntur recusandae. Doloribus molestiae, fuga facere nobis accusantium dignissimos ut architecto suscipit quo laborum."
          />
        </p>
      </div>

      <div class="col col-1 oka-show--md"></div>

      <div class="col col-8">
        <GrilleOffresApp />
      </div>
    </div>

    <!-- AI -->

    <div class="sok-offre flex-grid">
      <div class="col col-1 oka-show--md">
        <div class="sok-offre__indic -ia">
          <img
            class="sok-arrow"
            src={digitalArrow.src}
            alt="flèche"
            aria-hidden="true"
          />
          <span class="sok-num oka-data -xs -crop">04</span>
        </div>
      </div>

      <div class="sok-offre__colTitle col col-3">
        <div
          class="sok-offre__item -ia"
          data-offre="ia"
          data-offset-lg="top 30%"
        >
          <h3 class="oka-h -md">Intelligence Artificielle</h3>
        </div>
      </div>

      <div class="sok-offre__detail col col-3">
        <p>
          <Typper
            id="typper-ia-1"
            manual
            text="Lorem ipsum de l'intelligence artificielle dolor sit amet consectetur adipisicing elit. Adipisci maiores animi mollitia labore, nulla veniam voluptates consequuntur recusandae. Doloribus molestiae, fuga facere nobis accusantium dignissimos ut architecto suscipit quo laborum."
          />
        </p>
      </div>

      <div class="col col-1 oka-show--md"></div>

      <div class="col col-8">
        <GrilleOffresAi />
      </div>
    </div>

    <!-- IOT -->

    <div class="sok-offre flex-grid">
      <div class="col col-1 oka-show--md">
        <div class="sok-offre__indic -iot">
          <img
            class="sok-arrow"
            src={digitalArrow.src}
            alt="flèche"
            aria-hidden="true"
          />
          <span class="sok-num oka-data -xs -crop">05</span>
        </div>
      </div>

      <div class="sok-offre__colTitle col col-3">
        <div
          class="sok-offre__item -iot"
          data-offre="iot"
          data-offset-lg="top 30%"
        >
          <h3 class="oka-h -md">Internet des Objets</h3>
        </div>
      </div>

      <div class="sok-offre__detail col col-3">
        <p>
          <Typper
            id="typper-iot-1"
            manual
            text="Lorem ipsum de l'Internet des Objets dolor sit amet consectetur adipisicing elit. Adipisci maiores animi mollitia labore, nulla veniam voluptates consequuntur recusandae. Doloribus molestiae, fuga facere nobis accusantium dignissimos ut architecto suscipit quo laborum."
          />
        </p>
      </div>

      <div class="col col-1 oka-show--md"></div>

      <div class="col col-8">
        <GrilleOffresIot />
      </div>
    </div>
  </section>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const OFFRES = document.querySelectorAll<HTMLElement>("[data-offre]");
    const OFFRE_SCROLL_STEP = 500; // Distance de scroll virtuelle entre chaque déclenchement (en px)

    let mm = gsap.matchMedia();

    mm.add("(min-width: 1025px)", () => {
      ScrollTrigger.create({
        trigger: "#offres",
        start: "top top",
        end: `+=${(OFFRES.length + 1) * OFFRE_SCROLL_STEP}`,
        pin: true,
      });

      OFFRES.forEach((offre, index) => {
        const offreId = offre.dataset.offre;
        const sectionOffre = offre.closest(".sok-offre") as HTMLElement;

        ScrollTrigger.create({
          trigger: offre,
          start: `top+=${index * OFFRE_SCROLL_STEP}px 50%`,
          end: `bottom+=${index * OFFRE_SCROLL_STEP + OFFRE_SCROLL_STEP}px 50%`,
          onEnter: () => {
            offre.classList.add("-active");
            offre.classList.add("-display");
            sectionOffre.classList.add("-active");

            console.log("Entré dans l'offre :", offreId);
            document.dispatchEvent(
              new CustomEvent("offre:enter", { detail: { offre: offreId } }),
            );
            document.dispatchEvent(
              new CustomEvent("tipper:play", {
                detail: { id: `typper-${offreId}-1` },
              }),
            );
          },
          onEnterBack: () => {
            offre.classList.add("-active");
            sectionOffre.classList.add("-active");
            document.dispatchEvent(
              new CustomEvent("offre:enter", { detail: { offre: offreId } }),
            );
          },
          onLeave: () => {
            offre.classList.remove("-active");
            sectionOffre.classList.remove("-active");
            document.dispatchEvent(
              new CustomEvent("offre:leave", { detail: { offre: offreId } }),
            );
          },
          onLeaveBack: () => {
            offre.classList.remove("-active");
            sectionOffre.classList.remove("-active");
            document.dispatchEvent(
              new CustomEvent("offre:leave", { detail: { offre: offreId } }),
            );
          },
        });
      });
    });

    mm.add("(max-width: 1024px)", () => {
      OFFRES.forEach((offre) => {
        const offreId = offre.dataset.offre;
        const sectionOffre = offre.closest(".sok-offre") as HTMLElement;

        ScrollTrigger.create({
          trigger: sectionOffre,
          start: "top 85%",
          end: "bottom 15%",
          onEnter: () => {
            offre.classList.add("-active");
            offre.classList.add("-display");
            sectionOffre.classList.add("-active");
            document.dispatchEvent(
              new CustomEvent("offre:enter", { detail: { offre: offreId } }),
            );
            document.dispatchEvent(
              new CustomEvent("tipper:play", {
                detail: { id: `typper-${offreId}-1` },
              }),
            );
          },
          onEnterBack: () => {
            offre.classList.add("-active");
            sectionOffre.classList.add("-active");
            document.dispatchEvent(
              new CustomEvent("offre:enter", { detail: { offre: offreId } }),
            );
          },
          onLeave: () => {
            offre.classList.remove("-active");
            sectionOffre.classList.remove("-active");
            document.dispatchEvent(
              new CustomEvent("offre:leave", { detail: { offre: offreId } }),
            );
          },
          onLeaveBack: () => {
            offre.classList.remove("-active");
            sectionOffre.classList.remove("-active");
            document.dispatchEvent(
              new CustomEvent("offre:leave", { detail: { offre: offreId } }),
            );
          },
        });
      });
    });
  });
</script>

<style lang="scss">
  .sok-offres,
  .sok-section {
    position: relative;
    z-index: 1;
    margin: 0;
    border-radius: 0 0 var(--sok-radius-section) var(--sok-radius-section);
    background-color: var(--oka-color-layer-floor-0);
  }

  // Introduction de la section offres, avant le pin
  .sok-offres__intro {
    background-color: var(--oka-color-layer-floor-0);
  }

  @media (max-width: 1024px) {
    .sok-offres__intro {
      // ajustement de la taille pour mobile
      min-height: auto;
      padding-bottom: 2rem;

      .oka-h.-xl {
        font-size: clamp(1rem, 3.5dvh, 2.5rem);
        line-height: clamp(1.35rem, 4.5dvh, 3.25rem);
      }
    }
  }

  .oka-h {
    padding: 0;
  }

  .sok-offre {
    --sokOffre-item-height: 4rem;

    position: absolute;
    width: 100%;
    min-height: 100dvh;

    @media (max-width: 1024px) {
      // responsive Mobile
      //
      position: relative;
      min-height: auto;
      margin-bottom: 5rem; // Espacement entre les sections sur mobile

      flex-direction: column;
      flex-wrap: nowrap;
      gap: 0rem;
    }

    // offre de base,
    // sans thème,
    // utilisée pour donner une couleur de fond aux titres et détails
    &.-background {
      background: var(--oka-color-layer-floor-0);

      @media (max-width: 1024px) {
        display: none;
      }
    }

    &__colTitle {
      height: 3rem;

      @media (max-width: 1024px) {
        // Responsive uniquement Mobile
        flex: 0 0 4rem;
      }
    }

    &__item {
      height: var(--sokOffre-item-height);

      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 1rem 0;
      overflow: hidden;

      opacity: 0;
      @media (min-width: 1024px) {
        opacity: 0.3;
      }

      transition: all 0.3s ease; // Animation douce entre les états
      translate: 0rem 0px;

      pointer-events: none;

      &.-display {
        opacity: 0.3; // Apparaît gris/inactif même sur mobile
        @media (min-width: 1024px) {
          opacity: 0.3; // Reste gris/inactif sur bureau
        }

        pointer-events: all;
        translate: 0px 0px;
      }

      .-active & {
        //flex-direction: row-reverse;
        opacity: 1;
        font-weight: bold; // Passe explicitement en gras
        translate: 8px 0px;
      }

      & > .sok-arrow {
        margin-left: -2rem;
        zoom: 0.5;
        // transition: margin .15s ease-in-out;
        opacity: 0;
        transition: margin 0.15s cubic-bezier(0.63, 0.78, 0.25, 1);

        .-active & {
          margin-left: -1.05rem;
          margin-right: 1rem;
          opacity: 1;
        }
      }
    }

    @media (min-width: 1024px) {
      // Responsive : uniquement desktop
      .-web {
        position: absolute;
        top: calc(0 * var(--sokOffre-item-height));
      }
      .-metier {
        position: absolute;
        top: calc(1 * var(--sokOffre-item-height));
      }
      .-app {
        position: absolute;
        top: calc(2 * var(--sokOffre-item-height));
      }
      .-ia {
        position: absolute;
        top: calc(3 * var(--sokOffre-item-height));
      }
      .-iot {
        position: absolute;
        top: calc(4 * var(--sokOffre-item-height));
      }
    }

    &__indic {
      display: flex;
      align-items: center;
      gap: 0.5rem;

      height: var(--sokOffre-item-height);

      opacity: 0.3;
      pointer-events: none;

      .-active & {
        opacity: 1;
        pointer-events: all;
      }

      .sok-arrow {
        zoom: 0.5;
      }
    }

    &__detail {
      padding-right: 0rem;
      opacity: 0;
      transition: opacity 0.35s ease 0.75s;

      .-active & {
        opacity: 1;
      }
    }
  }
</style>
