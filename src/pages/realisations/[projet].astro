---
// ===== Layout =====
import Layout from "../../layouts/Layout.astro";

import Hibou from "./_Projets/components/Hibou.astro"

export function getStaticPaths() {
   return [
      { params: { projet: "hibou" } },
      { params: { projet: "travel" } },
      { params: { projet: "ramses" } },
      { params: { projet: "wecert" } },
      { params: { projet: "pegase" } },
      { params: { projet: "hugo" } },
   ];
}

const { projet } = Astro.params;

const components = {
   hibou: Hibou,
   // travel: Travel,
   // ramses: Ramses,
   // wecert: Wecert,
   // pegase: Pegase,
   // hugo: Hugo,
};

const ProjectComponent = components[projet as keyof typeof components];
---

<Layout title={projet || "Projet"} description={`Découvrez en détail notre réalisation pour le projet ${projet}.`}>
   <!-- Retourne le composant, si il existe -->
   {ProjectComponent ? <ProjectComponent /> : null}
   
   <!-- autre équivalant  -->
   <!-- {ProjectComponent && <ProjectComponent />} -->
</Layout>