---
// ===== Layout =====
import Layout from "../layouts/Layout.astro";
// ===== Componsants de la page =====
import TitreGlobal from "../components/equipe/TitreGlobal.astro";
import ParagrapheHistoire from "../components/equipe/ParagrapheHistoire.astro";

import TitreEquipe from "../components/equipe/TitreEquipe.astro";
import ParagrapheEquipe from "../components/equipe/ParagrapheEquipe.astro";


import TitreFormation from "../components/equipe/TitreFormation.astro";
import ParagrapheFormation from "../components/equipe/ParagrapheFormation.astro";

import TitreHommage from "../components/equipe/TitreHommage.astro";
import ParagrapheHommage from "../components/equipe/ParagrapheHommage.astro";
import ImageSok from "../components/commun/ImageSok.astro";
import Footer from '../components/commun/Footer.astro';
// ===== Composants d'animations =====

---

<Layout title="Page Équipe">
   <!-- ===== Section Histoire ===== -->
  <section class="_ctnr-inline">
    <div class="flex-grid">
      <div class="oka-spacer -xl"></div>
      
      <div class="col col-1"></div>

      <div class="col col-14">

        <TitreGlobal />

        <div class="oka-spacer -xl"></div>

        <div class="oka-cols -two">
            <div class="sok-gerants">
               <article class="sok-gerants__card">
                  <figure class="sok-gerants__img">
                     <ImageSok imagePath="/src/assets/images/equipe/gerants/Laurent-Costaouec.png" altText="kevin" />
                  </figure>

                  <div class="sok-gerants__infos">
                     <h3 class="oka-h -sm">Laurent Costaouec</h3>
                     <span class="oka-text -lg">Co-Fondateur / Co-Gérant</span>
                  </div>
               </article>

               <article class="sok-gerants__card">
                  <figure class="sok-gerants__img">
                     <ImageSok imagePath="/src/assets/images/equipe/gerants/Franck-Hortala.png" altText="kevin" />
                  </figure>

                  <div class="sok-gerants__infos">
                     <h3 class="oka-h -sm">Frank Hortola</h3>
                     <span class="oka-text -lg">Co-Fondateur / Co-Gérant</span>
                  </div>
               </article>

               <article class="sok-gerants__card">
                  <figure class="sok-gerants__img">
                     <ImageSok imagePath="/src/assets/images/equipe/gerants/Yann-Lorgueilleux.png" altText="kevin" />
                  </figure>

                  <div class="sok-gerants__infos">
                     <h3 class="oka-h -sm">Yann Lorgueilleux</h3>
                     <span class="oka-text -lg">Co-Gérant</span>
                  </div>
               </article>
            </div>

            <ParagrapheHistoire />
        </div>

        <div class="oka-spacer -xl"></div>

      </div>
    </div>
  </section>

   <!-- ===== Section Histoire ===== -->
  <section class="_ctnr-inline">
      <div class="flex-grid">
         <div class="oka-spacer -xl"></div>
         <div class="col col-1"></div>

         <div class="col col-14">
            <!-- === Partie équipe === -->
            <div class="oka-cols -two">
               <div>
                  
                  <TitreEquipe />
                  <ParagrapheEquipe />

                  <div class="oka-spacer -sm"></div>

                  <button class="oka-bt -lg">
                     <div class="oka-bt__lbl">call to action</div>
                     <div class="oka-spinner"></div>
                  </button>
               </div>

               <figure class="sok-equipe__img">
                  <ImageSok imagePath="/src/assets/images/equipe/equipe.jpg" altText="photo de l'équipe Hokoha" />
               </figure>
            </div>

            <div class="oka-spacer -xl"></div>

            <!-- === Partie "formation" === -->
            <div class="oka-cols -two">
               <div class="sok-hommage">
                  <TitreHommage />
                  <ParagrapheHommage />
               </div>

               <div class="sok-formation">
                  <TitreFormation />
                  <ParagrapheFormation />

                  <div class="oka-spacer -sm"></div>

                  <button class="oka-bt -lg">
                     <div class="oka-bt__lbl">call to action</div>
                     <div class="oka-spinner"></div>
                  </button>
               </div>
            </div>
         </div>

         <div class="oka-spacer -xl"></div>
      </div>
  </section>

   <div slot="Footer">
      <Footer modifier="-grey"/>
   </div>
</Layout>

<style lang="scss">
   .sok-gerants {
      display: flex;
      flex-direction: column;
      gap: .5rem;

      &__img {
         // width: 400px;
         height: 150px;
         aspect-ratio: 4 / 3;
         margin: 0;
         border: 2px solid red
      }
   }

   .sok-equipe__img {
      width: 100%;
      height: auto;
      aspect-ratio: 16/9;
      overflow: hidden;
      border-radius: 1rem;
   }

   .sok-hommage {
      display: flex;
      flex-direction: column;
      justify-content: end;
   }
</style>
