---
// ===== Layout =====
import Layout from '../layouts/Layout.astro';
// ===== Componsants de la page =====
import MediaWrapper from '../components/commun/MediaWrapper.astro';

// ===== Composants d'animations =====
import RevealText from '../animations/RevealText.astro';

// ===== Fichiers Markdown =====
import * as titreContact from "../contenus/contact/titre-contact.md";

// Props pour le conteu de meta:description
const { descContent = "lorem ipsum" } = Astro.props;
---

<Layout title="Page Contact" description={descContent}>
   <div class="oka-appWrap -full oka-lightMode oka-surface">
      <section class="_ctnr-inline">
         <div class="flex-grid">
            <div class="oka-spacer -xxl" aria-hidden="true"></div>

            <div class="col col-1"></div>

            <div class="col col-14">
               <RevealText>
                  <titreContact.Content />   
               </RevealText>

               <div class="oka-spacer -xl" aria-hidden="true"></div>
               <div class="oka-spacer -md" aria-hidden="true"></div>

               <div class="oka-cols -two">
                  <div class="sok-infos">
                     <div class="sok-infos__content">
                        <span class="oka-text -md">Téléphone :</span>
                        <h3 class="oka-h -md">+33 2 43 49 75 18</h3>
                     </div>

                     <div class="sok-infos__content">
                        <span class="oka-text -md">Email :</span>
                        <h3 class="oka-h-md">contact@hokoha.com</h3>
                     </div>

                     <div class="sok-infos__content">
                        <span class="oka-text -md">Adresse :</span>
                        <h3 class="oka-h -md">19 rue Eugène Messmer <br> Laval, 53000</h3>
                     </div>
                  </div>

                  <form class="sok-form" action="#">
                     <div class="sok-form__input-container">
                        <div class="l-form-row sok-form__input-wrapper">
                           <label class="oka-label-lg" for="form-prenom">Prénom</label>
                           <input class="oka-input -full" type="text" name="form-prenom" id="form-prenom" placeholder="John" pattern="^[A-Za-zÀ-ÿ' -]{2,50}$" required>
                        </div>
   
                        <div class="l-form-row sok-form__input-wrapper">
                           <label class="oka-label-lg" for="form-nom">Nom</label>
                           <input class="oka-input -full" type="text" name="form-nom" id="form-nom" placeholder="Doe" pattern="^[A-Za-zÀ-ÿ' -]{2,50}$" required>
                        </div>
                     </div>

                     <div class="l-form-row sok-form__input-wrapper">
                        <label class="oka-label-lg" for="form-email">Email</label>
                        <input class="oka-input -full" type="email" name="form-email" id="form-email" placeholder="email@domaine.com" pattern="^[^\s@]+@[^\s@]+\.[^\s@]{2,}$" required>
                     </div>

                     <div class="l-form-row sok-form__input-wrapper">
                        <label class="oka-label-lg" for="form-societe">Société (facultatif)</label>
                        <input class="oka-input -full" type="text" name="form-societe" id="form-societe" placeholder="votre société" pattern="^(?!\s*$).{1,1000}$">
                     </div>

                     <div class="l-form-row sok-form__input-wrapper">
                        <label class="oka-label-lg" for="form-tel">Téléphone</label>
                        <input class="oka-input -full" type="tel" name="form-tel" id="form-tel" placeholder="01 23 45 67 89" pattern="^\+?[0-9\s\-().]{8,20}$" required>
                     </div>

                     <div class="l-form-row sok-form__textarea-wrapper">
                        <label class="oka-label-lg" for="form-message">Message</label>
                        <textarea class="oka-input -full" name="form-message" id="form-message" placeholder="Votre message" maxlength="1000" required></textarea>
                     </div>

                      <button class="oka-bt " type="submit">
                           <span class="oka-bt__lbl">Envoyer</span>
                     </button>
                  </form>
               </div>
            </div>

         </div>

         <div class="oka-spacer -xl" aria-hidden="true"></div>
      </section>
   </div>

   <!-- Carte -->
   <div class="oka-appWrap -full oka-lightMode oka-surface">
      <section class="flex-grid">
         <div class="col col-16">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2666.7901248834614!2d-0.7690750228633499!3d48.05638990570631!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4808fdc238de79f5%3A0x3a4416f4d3315df7!2s19%20Rue%20Eug%C3%A8ne%20Messmer%2C%2053000%20Laval!5e0!3m2!1sfr!2sfr!4v1777017392278!5m2!1sfr!2sfr" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            <!-- <MediaWrapper ratio="2.5/1">
            </MediaWrapper> -->
         </div>

         <!-- <div class="oka-spacer -xl" aria-hidden="true"></div> -->
      </section>
   </div>

</Layout>

<style lang="scss">
   @use "../styles/oka-design-system/0-abstracts/breakpoints/breakpoints" as *;  
   @use "../styles/oka-design-system/2-elements/Forms/inputs/inputs" as *;

   .oka-appWrap:last-child {
      padding: 0 !important;
   }
   
   .oka-cols.-two {
      grid-template-areas: "col2" "col1";
      gap: 4rem;
      
      @include breakpoint(sm) {
         grid-template-areas: "col1 col2";
         gap: 0rem;
      }
   }

   .sok-infos {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      // max-width: 600px;
      // margin: 0 auto;
   }

   // Formulaire
   label {
      margin-bottom: 1rem;
      font-weight: bold;
   }

   input, textarea {
      padding: 1rem;

      // Style
      border: none;
      border-bottom: 2px solid var(--oka-color-fg);
      border-radius: 0;
      box-shadow: none;
      font-family: sans-serif;

      &::placeholder{
         font-style: normal;
         color: var(--oka-color-fg);
      }
   }

   .sok-form {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      width: 100%;
      // max-width: 600px;
      // margin: 0 auto;

      &__input-container,
      &__input-wrapper,
      &__textarea-wrapper {
         width: 100%;
      }

      &__input-container,
      &__textarea-wrapper {
         display: flex;
      }

      &__input-container {
         gap: 1rem;
      }

      &__textarea-wrapper {
         flex-direction: column;

         & textarea {
            min-height: 120px;
         }
      }
   }

   // Carte
   iframe {
      width: 100%;
      height: 50vh;
      border: none;
      outline: none;
      
      @include breakpoint(md) {
         height: 70vh;
      }
   }
</style>