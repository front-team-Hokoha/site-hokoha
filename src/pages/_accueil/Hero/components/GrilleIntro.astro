---
import { string } from "astro:schema";
import PolygoneFlip from "../../../../components/commun/polygones/PolygoneFlip.astro";
import PolygoneStatic from "../../../../components/commun/polygones/PolygoneStatic.astro";

interface Props {
  rows?: string;
  cols?:  string;
  ratio?: string;
  dataAttrs?: Record<string, string>;
}
const { rows, cols, ratio, dataAttrs } = Astro.props;

---

<div class="hex-grid -hidden" 
data-rows={rows ?? 1} 
data-cols={cols ?? 4} 
data-ratio={ratio ?? 0.1}
{...dataAttrs && Object.fromEntries(Object.entries(dataAttrs).map(([key, value]) => [`data-${key}`, value]))}

>
  <PolygoneStatic videoUrl="/src/assets/videos/test.mp4" />

  
  <PolygoneStatic imageUrl="/src/assets/images/ambiance/trame-video.jpg" />
  
  <PolygoneStatic imageUrl="/src/assets/images/environnement/developpement.jpg" alt="Développement web"/>
  <PolygoneStatic imageUrl="/src/assets/images/environnement/uxdesign.jpg" alt="Conception d'expérience utilisateur"/>



  <PolygoneFlip frontText="" backText="Back Texte" images={[
    {src: "/src/assets/images/test.jpg", alt: "dev: Kévin ALONZO"},
    {src: "/src/assets/images/environnement/uxdesign.jpg", alt: "Environnement de travail"}]}/>

  <PolygoneFlip frontText="" backText="Back Texte" images={[
    {src: "/src/assets/images/test2.jpg", alt: "dev: Kévin LARUE"},
    {src: "/src/assets/images/test.jpg", alt: "dev: Kévin ALONZO"}]} color="-metier"/>

  <!-- <PolygoneFlip frontText="" videoUrl="/src/assets/videos/test.mp4" color="-app" /> -->
   
  <!-- <PolygoneFlip frontText="" backText="Back Texte" images={[
    {src: "/src/assets/images/test.jpg", alt: "dev: Kévin ALONZO"},
    {src: "/src/assets/images/test2.jpg", alt: "dev: Kévin LARUE"}]} color="-web"/> -->

  <PolygoneFlip frontText="" backText=""  color="-metier"/>
  


</div>


<style>
/* Grille mobile : 4 colonnes, 2 lignes, ratio 0.1 */
@media (max-width: 1024px) {

  .hex-grid {
    grid-template-columns: repeat(2, 1fr) !important; 
    grid-template-rows: repeat(4, auto) !important;

    > *  {
      grid-area: auto / auto / auto / auto !important;

    }
  }
}
</style>