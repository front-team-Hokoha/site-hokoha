---
// ===== Composants de la page =====
import Grid from "../../../components/commun/grid.astro";
import GrilleIntro from "./components/GrilleIntro.astro";

// ===== Composants d'animations =====
import Revealtext from "../../../animations/RevealText.astro";
import RevealMask from "../../../animations/RevealMask.astro";

// ===== Fichiers Markdown =====
import * as paragrapheHero from "../../../contenus/accueil/hero/paragraphe-hero.md"


import { Image } from 'astro:assets';
import logokohaDark from '../../../assets/images/brand/logo_hokoha_developpement_color.png';

const grilleTop = [
  {
    type: "static",
    imageUrl: "/src/assets/images/ambiance/trame-video.jpg"
  },
  {
    type: "static",
    videoUrl: "/src/assets/videos/test.mp4",
    alt: "Vidéo de présentation"
  },
  {
    type: "static",
    imageUrl: "/src/assets/images/environnement/developpement.jpg",
    alt: "Développement web"
  },
  {
    type: "static",
    imageUrl: "/src/assets/images/environnement/uxdesign.jpg",
    alt: "Conception d'expérience utilisateur"
  },
  {
    type: "flip",
    frontText: "test",
    backText: "back test",
    color: "-metier"
  },
  {
    type: "static",
    imageUrl: "/src/assets/images/test2.jpg",
    alt: "Développement web"
  },
  {
    type: "flip",
    frontText: "",
    backText: "Back Texte",
    color: "-metier",
    images: [
      {
        src: "/src/assets/images/test2.jpg",
        alt: "dev: Kévin LARUE"
      },
      {
        src: "/src/assets/images/test.jpg",
        alt: "dev: Kévin ALONZO"
      }
    ]
  },
];

const grilleBottom = [
  {
    type: "static",
    imageUrl: "/src/assets/images/environnement/uxdesign.jpg",
    alt: "Conception UX"
  },
  {
    type: "static",
    imageUrl: "/src/assets/images/environnement/uxdesign.jpg",
    alt: "Conception UX"
  },

  {
    type: "flip",
    frontText: "",
    backText: "Back Texte",
    color: "-metier",
    images: [
      {
        src: "/src/assets/images/test2.jpg",
        alt: "dev: Kévin LARUE"
      },
      {
        src: "/src/assets/images/test.jpg",
        alt: "dev: Kévin ALONZO"
      }
    ]
  },

  {
    type: "flip",
    frontText: "test",
    backText: "back test",
    color: "-app"
  }
];
---

<div class="oka-appWrap -full">
   <section class="sok-hero">
      
      <!-- <Grid /> -->

      <div class="flex-grid">
         <div class="col col-1"></div>
   
         <div class="col col-9">
            <div class="oka-spacer  -xxl oka-hide--md" aria-hidden="true"></div>
            <div class="oka-spacer  -lg oka-show--md" aria-hidden="true"></div>

            <div class="oka-spacer  -xxl" aria-hidden="true"></div>
   

            <Image
               src={logokohaDark}
               alt="Logotype : société Hokoha développement informatique"
               width={297.5}
               height={56}
               format="webp"
               quality={80}
               loading="eager"
               class=""
               densities={[1, 2]}
            />

            <div class="oka-spacer  -md" aria-hidden="true"></div>

            <h1 class="oka-h -xl -secondary">
               Développement informatique sur-mesure
            </h1>


            <div class="oka-spacer  -sm" aria-hidden="true"></div>
           
            <paragrapheHero.Content />
   
            <div class="oka-spacer  -lg" aria-hidden="true"></div>
              
         </div>
       
         <div class="col col-1">
            <!-- <GrilleIntro cols="2" /> -->
         </div>
      </div>
   
      <div class="flex-grid">
         <div class="col col-2">
         
         </div>
         <div class="col col-14">
             <GrilleIntro cols="7" rows="1" ratio="0" dataAttrs={{ appearGroup: "", delay: "0.4" }} items={grilleTop} />
         </div>
      </div>

      <!-- Mobile: GrilleIntro visible only on mobile (oka-show--md) -->
      <div class="flex-grid oka-show--md">
         <div class="col col-8"></div>
         <div class="col col-8">
            <GrilleIntro
               cols="4"
               rows="1"
               dataAttrs={{ appearGroup: "", delay: "1.5" }}
               items={grilleBottom}
            />
            <div class="oka-spacer -xxl" aria-hidden="true"></div>
         </div>
      </div>

   </section>
</div>



<style lang="scss" is:global>

   @use "../../../styles/oka-design-system/2-elements/typography-brand/texts/texts.scss" as *;

   .sok-hero {
      position:relative;
      z-index: 2;

      margin:0;
      
   }

   .sok-logokoha{
      width: auto;
      height: 56px;
   }


   .oka-text p,
   .sok-hero__chapeau p {
      @extend %oka-text-lg;
      max-width: 840px;
   }


</style>




