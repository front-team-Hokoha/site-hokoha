---
// ===== Componsants de la page =====
import PictoLight from "../../../components/commun/PictoLight.astro";

import CardSavoirFaire from "./components/CardSavoirFaire.astro"
// import Grid from "../../components/commun/grid.astro";
// ===== Composants d'animations =====
import Revealtext from "../../../animations/RevealText.astro";

// ==== Import du fichier Markdown
import * as titreSavoirFaire from "../../../contenus/accueil/savoir-faires/titre-savoir-faire.md"
import * as paragrapheSavoirFaire from "../../../contenus/accueil/savoir-faires/paragraphe-savoir-faire.md"
---
<div class="oka-appWrap -full oka-darkMode oka-surface">
  <section class="sok-sf" id="sok-sf">
  
    <div class="hgo-snap oka-appWrap -fluid -firstWrap">
      <section class="sok-savoirfaire">

            <div class="flex-grid sok-savoirfaire__wrapper">
              <div class="col col-1 pictoCol" aria-hidden="true">
                <PictoLight />
              </div>

              <div class="col col-14 sok-savoirfaire__content-container">
                <div class="flex-grid">
    
                  <div class="col col-7 sok-savoirfaire__content" aria-hidden="true">
                    <div class="sok-savoirfaire__titles">
                      
                      
                      <div class="oka-spacer -lg" aria-hidden="true"></div>
                      

         
                      <span class="oka-text -xs ">NOTRE SAVOIR-FAIRE</span>
               
                      <Revealtext>
                        <titreSavoirFaire.Content />
                      </Revealtext>
                      
                      <!-- <Revealtext>
                        <h2 class="oka-h -md -secondary">
                        Lorem ipsum dolor sit, amet consectetur <span>adipisicing</span> elit 
                        similique dolore eius iusto accusantium.
                        </h2>
                      </Revealtext> -->
              
                   
                    </div>
                  </div>
    
                  <div class="col col-7 sok-savoirfaire__quote-wrapper" aria-hidden="true">
                    <div class="oka-spacer -xl oka-hide--md" aria-hidden="true"></div> 

                      <div class="sok-paragraph">
                        <paragrapheSavoirFaire.Content />
                      </div>
                    
                  </div>
                  
                </div>
              </div>
              
            </div>

      </section>
    </div>
    
    <div class="oka-appWrap -fluid -secondWrap">  
      <section class="sok-savoirfaire__cards">
        <div class="sok-card-container">
          <CardSavoirFaire />
        </div>
      </section>    
    </div>
  </section>

</div>


<style lang="scss">
  @use "../../../styles/oka-design-system/0-abstracts/breakpoints/breakpoints" as *;  
  // oka-appWrap des deux sections
  .-firstWrap,.-secondWrap { padding: 0; }

  .pictoCol {
    padding-top: 2.25rem;
    padding-left: 2.5rem;
  }
  
  .sok-savoirfaire {
    
    &__wrapper {
      background-color: var(--oka-color-layer-floor-0);
      border: 1px solid var(--oka-color-bd-minimal);

      @include breakpoint(md) {
        min-height: 35dvh;
        //align-items: top;
      }
    }
    
    &__quote-wrapper {
      margin-top: 2rem;

      @include breakpoint(md) {
        margin-top: 0;
        display: flex;
        justify-content: end;
        align-items: end;
      }
    }
  }

  // Container des cartes
  .sok-card-container {
    @include breakpoint(md) {
      display: flex;
    }
  }
</style>


<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {

    // ─── Éléments cibles ────────────────────────────────────────────────────────
    // #offres   : la section qui va se flouter / rétrécir (au-dessus dans le DOM)
    // #sok-sf   : la section dont l'entrée déclenche l'effet
    const offres = document.querySelector<HTMLElement>("#offres");
    const sokSf  = document.querySelector<HTMLElement>("#sok-sf");

    // Sécurité : si l'un des deux éléments est absent on ne plante pas
    if (!offres || !sokSf) return;

    // ─── Optimisation GPU ───────────────────────────────────────────────────────
    // Annonce au navigateur que transform et filter vont changer → layer dédié
    gsap.set(offres, { willChange: "transform, opacity" });

    // ─── Animation liée au scroll (scrub) ───────────────────────────────────────
    // gsap.timeline + scrollTrigger.scrub = chaque px de scroll = x% d'animation
    gsap.timeline({
      scrollTrigger: {
        trigger : sokSf,         // ScrollTrigger observe #sok-sf
        start   : "top bottom",  // début : le haut de #sok-sf touche le BAS du viewport
        end     : "top center",  // fin   : le haut de #sok-sf atteint le CENTRE du viewport
        scrub   : 1,             // 1 s de lissage entre scroll et animation (0 = instantané)
        // markers: true,        // ← décommenter pour déboguer les points de déclenchement
      },
    })
    .to(offres, {
      //filter       : "blur(8px)",  // flou progressif (pixels)
      scale          : 0.94,         // légère réduction d'échelle
      opacity        : 0.13,         // légère diminution d'opacité
      transformOrigin: "center top", // rétrécit depuis le haut de #offres
      ease           : "none",       // linéaire obligatoire sur un scrub scrubbed timeline
    });

  });
</script>

