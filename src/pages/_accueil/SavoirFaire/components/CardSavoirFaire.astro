---
// ===== Composants utilisés =====

import { Image } from 'astro:assets';
// import ImageSok from "../../../../components/commun/ImageSok.astro";
// import Revealtext from "../../../../animations/RevealText.astro";
// import MediaWrapper from "../../commun/MediaWrapper.astro";


// Image
import bandeau from '../../../../assets/images/ambiance/176.jpg';



// ===== Fichiers Markdown =====
const savoirFaires = Object.values(
  import.meta.glob<Record<string, any>>("../../../../contenus/accueil/savoir-faires/cartes/*.md", {
    eager: true,
  }),
);

---

{
  savoirFaires.map((savoirFaire) => (
    <article class="sok-card">
      <div class="sok-card__container">
        
        
   
        <div class="side-wrapper">
          <div class="sok-card__side">
            <div class="oka-h -sm -secondary">{savoirFaire.frontmatter.tag}</div>

            <span class="oka-data -sm -strong">
              {savoirFaire.frontmatter.num}
            </span>


            <div class="bandeau-image">
              <Image
                src={bandeau}
                alt="Logotype : société Hokoha développement informatique"
                width={990}
                height={660}
                format="webp"
                quality={80}
                loading="eager"
                class=""
                densities={[1, 2]}
              />
            </div>



          </div>
        </div>

        <div class="card-content-container">
          <div class="sok-card__content-wrapper">

            


            <div class="texts-wrapper">
              <div class="sok-card__content">
                <h3 class="oka-h -xxl"
                  set:html={savoirFaire.frontmatter.title}
                />
                <div class="oka-spacer  -md" aria-hidden="true"></div>
                <div class="sok-paragraph">
                  <p class="oka-text -md">{savoirFaire.rawContent()}</p>
                </div>

                <div class="oka-spacer -md" aria-hidden="true" />

                <button class="oka-bt -outlined">
                  <div class="oka-bt__lbl">En savoir plus</div>
                </button>
              </div>
            </div>


        <div class="image-wrapper">
              <div class="oka-spacer -xl -spacing" aria-hidden="true" />

              {/* <figure class="sok-card__image-inner">
                <ImageSok imagePath={savoirFaire.frontmatter.src} altText={savoirFaire.frontmatter.alt} />
              </figure> */}
            </div> 

            
          </div>
        </div>
      </div>
    </article>
  ))
}


<!-- Conclusion -->
 <article class="sok-card">
      <div class="sok-card__container">
        
        <div class="card-content-container">
          <div class="sok-card__content-wrapper">

            <div class="bandeau-image conclusion-image-ctnr">
              <Image
                src={bandeau}
                alt="Logotype : société Hokoha développement informatique"
                width={990}
                height={660}
                format="webp"
                quality={80}
                loading="eager"
                class="conclusion-image"
                densities={[1, 2]}
              />

            </div>

            <div class="texts-wrapper">
              <div class="sok-card__content">
               <div class="oka-spacer  -xxl" aria-hidden="true"></div>
                <div class="oka-spacer  -xxl" aria-hidden="true"></div>
                <div class="oka-spacer  -xxl" aria-hidden="true"></div>	
                <div class="oka-spacer  -xxl" aria-hidden="true"></div>
       
                <h3 class="oka-h -xxl">“Notre seul but est de faire bien.”</h3>
                <div class="oka-spacer  -md" aria-hidden="true"></div>
                <p class="oka-text -md">Ernő Rubik - Inventeur du Rubik’s Cube</p>
       

                <div class="oka-spacer -md" aria-hidden="true" />

                
              </div>
            </div>

            
          </div>
        </div>
      </div>
    </article>









<style lang="scss">
  @use "../../../../styles/oka-design-system/0-abstracts//breakpoints/breakpoints"
    as *;

  :root {
    // Sert à calculer la taille d'une ou plusieurs colonne par rapport au viewport
    // 1 col = calc((100dvw / 16) * 1)
    --col-size: calc(100dvw / 16);
  }

  .-spacing {
    @include breakpoint(md) {
      display: none;
    }
  }

  .sok-card {
    position: relative;
    z-index: 99;
    // margin-bottom: -1px;
    // background-color: var(--oka-color-layer-floor-0);
    border: 0px solid var(--oka-color-bd-minimal);

    .sok-card__container {
      overflow: hidden;
      gap: 0;

      @include breakpoint(md) {
        display: flex;
        min-height: 100dvh; // 30dvh de plus , pour debords après le scroll
      }

      // ===== Bandeau latéral =====
      .side-wrapper {
        display: none;
        //flex: 0 0 calc(var(--col-size) * 8);

        //background-color: #fff; //var(--oka-color-bg-on_surface);

        @include breakpoint(md) {
          display:block;
          flex: 0 0 calc(var(--col-size) * 1);

          position: relative;
          z-index: 2;
          //backdrop-filter: blur(4px);
          //background: rgba(0, 0, 0, 0.8);
          
        }

        .sok-card__side {
          position: relative;
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 1rem;
          border-bottom: 1px solid var(--oka-color-bd-minimal);

          overflow: hidden; // Requi pour illustr du bandeau

          @include breakpoint(md) {
            flex-direction: column;
            height: 100%;
            padding: 2rem 0rem;
            border-right: 1px solid var(--oka-color-bd-minimal);
            border-bottom: none;
          }

          & > * {
            // color: var(--oka-color-fg-subtle);
            writing-mode: horizontal-tb;

            @include breakpoint(md) {
              writing-mode: sideways-lr;
            }
          }

          .oka-h {
            padding: 0;
          }

          .bandeau-image {
            display: none;

            @include breakpoint(md) {
              display: block;
              position: absolute;
              top: 0;
              left: 0;
              width: calc(var(--col-size) * 4); // bandeau fait 4 colonnes de large
              height: 100%;
              opacity: 0.4;
              z-index: -1;
            }
          }
        }
      }

      // ===== Contenu des cartes =====
      .sok-card__content-wrapper {
        @include breakpoint(md) {

          display: flex;
          height: 100%;

       
          z-index: 0;
        }

        .texts-wrapper {
          flex: 0 0 calc(var(--col-size) * 8);
          padding: 1rem;

          @include breakpoint(md) {
            flex: 0 0 calc(var(--col-size) * 8);
            //margin: 2rem;
            padding: 0;
          }

          @include breakpoint(lg) {
            flex: 0 0 calc(var(--col-size) * 8);

            padding-top: calc(var(--col-size) * 1);
            padding-left: calc(var(--col-size) * 1);
          }

          .sok-card__content {
            .oka-h {
              width: 100%;
              //color: var(--oka-color-fg-subtle);
              // max-width: 740px;
              // max-width: 605px;

              @include breakpoint(lg) {
                // min-width:  605px;
              }
            }

            .sok-paragraph {
              max-width: 480px;
              text-align: justify;

              @include breakpoint(md) {
                // min-width: 480px;
                text-align: start;
              }
            }
          }
        }

        // ===== Image =====
        .image-wrapper {
          flex: 0 0 calc(var(--col-size) * 8);

          @include breakpoint(md) {
            flex: 0 0 calc(var(--col-size) * 4);
            //margin: 2rem;
          }

          .sok-card__image-inner {
            width: 100%;
            height: clamp(225px, 25vh, 300px);
            margin: 0;
            padding: 1rem;

            @include breakpoint(md) {
              height: 100%;
              padding: 0;
            }

            & img {
        
              width: 100%;
              height: 100%;
              object-fit: cover;
            }
          }
        }
      }
    }
  }

 

.sok-card:nth-child(1n) .image-wrapper {
  @include breakpoint(lg) {
    flex: 0 0 calc(var(--col-size) * 6) !important;
  }
}
.sok-card:nth-child(2n) .image-wrapper {
  @include breakpoint(lg) {
    flex: 0 0 calc(var(--col-size) * 5) !important;
  }
}
.sok-card:nth-child(3n) .image-wrapper {
  @include breakpoint(lg) {
    flex: 0 0 calc(var(--col-size) * 4) !important;
  }
}
.sok-card:nth-child(4n) .image-wrapper {
  @include breakpoint(lg) {
    flex: 0 0 calc(var(--col-size) * 4) !important;
  }
}

</style>

<style lang="scss" global>




  .bandeau-image img {
    width: 100dvw;
    height: 100dvh;
    object-fit: cover;
    object-position: top;

  }

  // decalage des bandeau images
  .sok-card:nth-child(2n) .bandeau-image img {
    margin-left:(calc(var(--col-size) * -1));
  }
  .sok-card:nth-child(3n) .bandeau-image img {
    margin-left:(calc(var(--col-size) * -2));
  }
  .sok-card:nth-child(4n) .bandeau-image img {
    margin-left:(calc(var(--col-size) * -3));
  }

  .conclusion-image-ctnr {
    position: absolute;
    z-index: -1;
    overflow: hidden;
    opacity: 0.4;
    }
  
  .conclusion-image {
    width: 100dvw;
    height: auto;
    margin-left:(calc(var(--col-size) * -4));
    object-fit: cover;
    object-position: center;
    }
</style>




<!-- GSAP -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const cardsWrapper = document.querySelector(".sok-card-container");
    if (!cardsWrapper) return;

    const sokCards = document.querySelectorAll(".sok-card");
    if (!sokCards.length) return;

    const lastIndex = sokCards.length - 1;

    // 🔥 nouvelle API
    const matchMedia = gsap.matchMedia();

    matchMedia.add("(min-width: 1024px)", () => {
      console.log("GSAP activé (desktop)");

      const totalWidth = cardsWrapper.scrollWidth;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".sok-sf", // Première section de SavoirFaire.astro
          start: "top top",
          end: () => `+=${totalWidth}`,
          scrub: true,
          pin: true,
          anticipatePin: 1,
          // markers: true,
        },
      });

      sokCards.forEach((sokCard, i) => {
        // Rétrécie toutes les cartes sauf la dernière
        if (i === lastIndex) return;

        const rightContent = sokCard.querySelector(
          ".sok-card__content-wrapper"
        );

        if (rightContent) {
          tl.to(
            rightContent,
            {
              width: 0,
              duration: 1,
            },
            i
          );
        }
      });

      // GPTo
      // 🧹 cleanup automatique quand on sort du breakpoint
      return () => {
        console.log("cleanup desktop");

        tl.kill();

        gsap.set(".sok-card__content-wrapper", {
          clearProps: "all",
        });
      };
    });

        // GPTo
    matchMedia.add("(max-width: 1023px)", () => {
      console.log("mode mobile");

      // reset sécurité
      gsap.set(".sok-card__content-wrapper", {
        clearProps: "all",
      });
    });
  });
</script>

