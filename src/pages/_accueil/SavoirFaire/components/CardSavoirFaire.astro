---
// ===== Composants utilisés =====
import ImageSok from "../../../../components/commun/ImageSok.astro";
// import MediaWrapper from "../../commun/MediaWrapper.astro";

// ===== Fichiers Markdown =====
const savoirFaires = Object.values(
  import.meta.glob<Record<string, any>>("../../../../contenus/accueil/savoir-faires/cartes/*.md", {
    eager: true,
  }),
);
---

{
  savoirFaires.map((savoirFaire) => (
    <article class="sok-card">
      <div class="sok-card__container">
        {/* bandeau */}
        <div class="side-wrapper">
          <div class="sok-card__side">
            <h3 class="oka-h -sm -secondary">{savoirFaire.frontmatter.tag}</h3>

            <span class="oka-data -sm -strong">
              {savoirFaire.frontmatter.num}
            </span>
          </div>
        </div>

        <div class="card-content-container">
          <div class="sok-card__content-wrapper">
            <div class="texts-wrapper">
              <div class="sok-card__content">
                <h3
                  class="oka-h -lg"
                  set:html={savoirFaire.frontmatter.title}
                />

                <div class="sok-paragraph">
                  <p class="oka-text -md">{savoirFaire.rawContent()}</p>
                </div>

                <div class="oka-spacer -md" aria-hidden="true" />

                <button class="oka-bt -outlined">
                  <div class="oka-bt__lbl">En savoir plus</div>
                </button>
              </div>
            </div>

            <div class="image-wrapper">
              <div class="oka-spacer -xl -spacing" aria-hidden="true" />

              <figure class="sok-card__image-inner">
                <ImageSok imagePath={savoirFaire.frontmatter.src} altText={savoirFaire.frontmatter.alt} />
              </figure>
            </div>
          </div>
        </div>
      </div>
    </article>
  ))
}

<style lang="scss">
  @use "../../../../styles/oka-design-system/0-abstracts//breakpoints/breakpoints"
    as *;

  :root {
    // Sert à calculer la taille d'une ou plusieurs colonne par rapport au viewport
    // 1 col = calc((100dvw / 16) * 1)
    --col-size: calc(100dvw / 16);
  }

  .-spacing {
    @include breakpoint(md) {
      display: none;
    }
  }

  .sok-card {
    position: relative;
    z-index: 99;
    // margin-bottom: -1px;
    // background-color: var(--oka-color-layer-floor-0);
    border: 1px solid var(--oka-color-bd-minimal);

    .sok-card__container {
      overflow: hidden;
      gap: 0;

      @include breakpoint(md) {
        display: flex;
        min-height: 50vh;
      }

      // ===== Bandeau latéral =====
      .side-wrapper {
        flex: 0 0 calc(var(--col-size) * 8);

        @include breakpoint(md) {
          flex: 0 0 calc(var(--col-size) * 1);
        }

        .sok-card__side {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 1rem;
          border-bottom: 1px solid var(--oka-color-bd-minimal);

          @include breakpoint(md) {
            flex-direction: column;
            height: 100%;
            padding: 2rem 0rem;
            border-right: 1px solid var(--oka-color-bd-minimal);
            border-bottom: none;
          }

          & > * {
            writing-mode: horizontal-tb;

            @include breakpoint(md) {
              writing-mode: sideways-lr;
            }
          }

          .oka-h {
            padding: 0;
          }
        }
      }

      // ===== Contenu des cartes =====
      .sok-card__content-wrapper {
        @include breakpoint(md) {
          display: flex;
          height: 100%;
        }

        .texts-wrapper {
          flex: 0 0 calc(var(--col-size) * 8);
          padding: 1rem;

          @include breakpoint(md) {
            flex: 0 0 calc(var(--col-size) * 5);
            margin: 2rem;
            padding: 0;
          }

          @include breakpoint(lg) {
            flex: 0 0 calc(var(--col-size) * 6);
          }

          .sok-card__content {
            .oka-h {
              width: 100%;
              // max-width: 740px;
              // max-width: 605px;

              @include breakpoint(lg) {
                // min-width:  605px;
              }
            }

            .sok-paragraph {
              max-width: 480px;
              text-align: justify;

              @include breakpoint(md) {
                // min-width: 480px;
                text-align: start;
              }
            }
          }
        }

        // ===== Image =====
        .image-wrapper {
          flex: 0 0 calc(var(--col-size) * 8);

          @include breakpoint(md) {
            flex: 0 0 calc(var(--col-size) * 3);
            margin: 2rem;
          }

          .sok-card__image-inner {
            width: 100%;
            height: clamp(225px, 25vh, 300px);
            margin: 0;
            padding: 1rem;

            @include breakpoint(md) {
              height: 100%;
              padding: 0;
            }

            & img {
              width: 100%;
              height: 100%;
              object-fit: cover;
            }
          }
        }
      }
    }
  }
</style>

<!-- GSAP -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const cardsWrapper = document.querySelector(".sok-card-container");
    if (!cardsWrapper) return;

    const sokCards = document.querySelectorAll(".sok-card");
    if (!sokCards.length) return;

    const lastIndex = sokCards.length - 1;

    // 🔥 nouvelle API
    const matchMedia = gsap.matchMedia();

    matchMedia.add("(min-width: 1024px)", () => {
      console.log("GSAP activé (desktop)");

      const totalWidth = cardsWrapper.scrollWidth;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".sok-sf", // Première section de SavoirFaire.astro
          start: "top top",
          end: () => `+=${totalWidth}`,
          scrub: true,
          pin: true,
          anticipatePin: 1,
          // markers: true,
        },
      });

      sokCards.forEach((sokCard, i) => {
        // Rétrécie toutes les cartes sauf la dernière
        if (i === lastIndex) return;

        const rightContent = sokCard.querySelector(
          ".sok-card__content-wrapper"
        );

        if (rightContent) {
          tl.to(
            rightContent,
            {
              width: 0,
              duration: 1,
            },
            i
          );
        }
      });

      // GPTo
      // 🧹 cleanup automatique quand on sort du breakpoint
      return () => {
        console.log("cleanup desktop");

        tl.kill();

        gsap.set(".sok-card__content-wrapper", {
          clearProps: "all",
        });
      };
    });

        // GPTo
    matchMedia.add("(max-width: 1023px)", () => {
      console.log("mode mobile");

      // reset sécurité
      gsap.set(".sok-card__content-wrapper", {
        clearProps: "all",
      });
    });
  });
</script>

