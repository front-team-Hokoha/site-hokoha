---
import PolygoneFlipProg from "../../../../components/commun/polygones/PolygoneFlipProg.astro";
import PolygoneFlip from "../../../../components/commun/polygones/PolygoneFlip.astro";
---

<div id="grilleTagsNone" class="sok-offre__grid hex-grid -hidden" data-rows="3" data-cols="5" data-ratio="0.35" data-appeargroup>

  <!-- Poly par default -->
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none"  />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none"  />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none" colorFront="-default" />
  <PolygoneFlipProg type="-none" colorFront="-default" /> 

  



</div>



<style lang="scss" is:global>
  .hex-grid {
    display: grid;
    gap: 2px;
    margin-bottom:2px;
    
    /* Layout CSS pur pour éviter le Cumulative Layout Shift (CLS) */
    &[data-cols="1"] { grid-template-columns: repeat(1, 1fr); }
    &[data-cols="2"] { grid-template-columns: repeat(2, 1fr); }
    &[data-cols="3"] { grid-template-columns: repeat(3, 1fr); }
    &[data-cols="4"] { grid-template-columns: repeat(4, 1fr); }
    &[data-cols="5"] { grid-template-columns: repeat(5, 1fr); }
    &[data-cols="6"] { grid-template-columns: repeat(6, 1fr); }
    &[data-cols="7"] { grid-template-columns: repeat(7, 1fr); }

    svg {
      overflow: visible; // permet au stroke de ne pas être rogné par le viewport SVG
    }

    &.-hidden {
			visibility: hidden;	
		}
  }

  .polygone {
    transition: opacity 0.4s ease, filter 0.4s ease;
  }

  .sok-offre__grid{
    position: relative;
    z-index: 2;
  }


  // Responsive uniquement Mobile
  @media (max-width: 1024px) {

    .sok-offre__grid {
      grid-template-columns: repeat(3, 1fr) !important; 
      grid-template-rows: repeat(6, auto) !important;

      > *  {
        grid-area: auto / auto / auto / auto !important;

      }
    }
  }


#grilleTagsNone {
  z-index: -1;
}
</style>


<script>
function layoutGrid(grid: HTMLElement) {
  const COLS        = Number(grid.dataset.cols);
  const ROWS        = Number(grid.dataset.rows);
  const EMPTY_RATIO = Number(grid.dataset.ratio);
  const DELAY = 0.035;

  const svgs = Array.from(grid.querySelectorAll<HTMLElement>('.polygone'));

  grid.style.gridTemplateColumns = `repeat(${COLS}, 1fr)`;
  grid.style.gridTemplateRows = `repeat(${ROWS}, auto)`;


  const positions: { row: number; col: number }[] = [];
  for (let row = 1; row <= ROWS; row++) {
    for (let col = 1; col <= COLS; col++) {
      positions.push({ row, col });
    }
  }

  // Mélange aléatoire des positions (Fisher-Yates)
  for (let i = positions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [positions[i], positions[j]] = [positions[j], positions[i]];
  }

  // Masque un nombre de polygones proportionnel à EMPTY_RATIO
  const visibleCount = Math.round(positions.length * (1 - EMPTY_RATIO));

  svgs.forEach((svg, i) => {
    if (i >= positions.length) { svg.style.display = 'none'; return; }
    const { row, col } = positions[i];
    svg.style.gridColumn = String(col);
    svg.style.gridRow    = String(row);
    svg.classList.remove('-visible', '-hidden');
    svg.classList.add(i < visibleCount ? '-visible' : '-hidden');
    svg.dataset.delay = String(i * DELAY);
  });
}





// Attendre que la page soit complètement chargée
document.addEventListener("astro:page-load", () => {

  const grids = document.querySelectorAll<HTMLElement>('.hex-grid');
  
  // Appliquer la mise en page à chaque grille
  grids.forEach((grid) => {
    
    grid.classList.remove("-hidden");
    layoutGrid(grid);
  });


});
</script>