<style lang="scss">

    :global([data-appeargroup] > *) {
        opacity: 0;
        transform: translateY(120px);
    }

</style>


<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);
  
    document.addEventListener("astro:page-load", () => {

        const startPosition = window.matchMedia("(max-width: 768px)").matches ? "top 80%" : "top 70%";

        document.querySelectorAll('[data-appeargroup]').forEach(group => {

            const children = Array.from(group.children);
            if (children.length === 0) return;

            const dataDelay = group.dataset.delay ? parseFloat(group.dataset.delay) : 0;

            const timeline = gsap.timeline({
                delay: dataDelay,
                scrollTrigger: {
                    trigger: group,
                    start: startPosition,
                    toggleActions: "play none none none"
                }
            });

            children.forEach((child, i) => {
                timeline.to(child, {
                    opacity: 1,
                    y: 0,
                    duration: 0.25
                }, i === 0 ? undefined : "-=0.15");
            });
        });
    });
</script>