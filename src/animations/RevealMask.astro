<div class="sok-container">
   <slot />
</div>

<script>
   import { gsap } from "gsap";

   const tl = gsap.timeline();
   const maskContainer = document.querySelector('.maskContainer');
   console.log(maskContainer);
   
   const polygons = maskContainer.querySelectorAll('.polygone[visibility="visible"]');

   // Settings
   const amount = 2; // durée totale en seconde de l'animation
   const from = "start"; // valeur possible : "start", "center", "end", "edges" ou "random"
   const axis = "x"; // valeur possible : "x" ou "y"

   function maskAnimation(amount: number, from: string, axis: "x" | "y") {
      tl.to(polygons, {
         scale: 0.1,
         rotate: 360,
         ease: "power2.out",
         stagger: {
            amount: amount,
            grid: [5, 4],
            from: from,
            axis: axis,
         },
      })
   }

   document.addEventListener("astro:page-load", () => {
      maskAnimation(amount, from, axis);
   });
</script>