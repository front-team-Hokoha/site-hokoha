<!--
  RevealText — Animation d'apparition de texte ligne par ligne

  Enveloppe n'importe quel contenu textuel dans un conteneur animé au scroll.
  Chaque ligne apparaît par un glissement vertical avec un léger fondu.

  Usage :
    <RevealText>
      <h2>Mon titre</h2>
      <p>Mon paragraphe</p>
    </RevealText>

  Data-attributes :
    data-delay="{number}"      — Délai en secondes avant le lancement de l'animation (défaut : 0)
                                 ex: data-delay="0.5"
    data-offset-sm="{string}"  — Position de déclenchement sur mobile (défaut : "top 90%")
                                 ex: data-offset-sm="top 80%"
    data-offset-lg="{string}"  — Position de déclenchement sur desktop (défaut : "top 90%")
                                 ex: data-offset-lg="top 60%"

  Exemple complet :
    <RevealText data-delay="0.3" data-offset-lg="top 70%">
      <h2>Titre animé</h2>
    </RevealText>
-->
---
interface Props {
    'data-delay'?: string;
    'data-offset-sm'?: string;
    'data-offset-lg'?: string;
}

const {
    'data-delay': delay,
    'data-offset-sm': offsetSm,
    'data-offset-lg': offsetLg,
} = Astro.props;
---

<div
    class="reveal-text -hidden"
    data-delay={delay}
    data-offset-sm={offsetSm}
    data-offset-lg={offsetLg}
>
  <slot />
</div>


<style lang="scss">
	.reveal-text {
		&.-hidden {
			visibility: hidden;	
		}
	}
</style>


<script>
	import { gsap } from "gsap";
	import { SplitText } from "gsap/SplitText";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { getStartPosition } from "./animationConfig.js";

	gsap.registerPlugin(SplitText, ScrollTrigger);

	// Charger les éléments dès que la page est chargée
	document.addEventListener("astro:page-load", () => {

		const revealtextes = document.querySelectorAll(".reveal-text");

		// Vérifie si les components Revealtext existent sur la page
		if (!revealtextes.length) return;

		// Créer une animation de reveal lors du scroll pour chaque Revealtext
		revealtextes.forEach((revealtext) => {

			// Fixer la hauteur du container à l'init pour éviter les flashs de layout
			revealtext.style.height = revealtext.offsetHeight + "px";

			ScrollTrigger.create({
				trigger: revealtext,
				start: getStartPosition(revealtext),
				once: true,
				markers: true,
				onEnter: () => {
					// Affiche les éléments
					revealtext.classList.remove("-hidden");

					// Créer une animation de split pour chaques lignes
					SplitText.create(revealtext, {
						type: "lines",
						autoSplit: true,
						mask: "lines",
						onSplit: (self) => {
							// Ajouter du padding pour les descendantes (p, q, g, y, j...)
							// compensé par un margin négatif pour ne pas décaler le layout
							self.lines.forEach((line) => {
								const wrapper = line.parentElement;
								if (wrapper) {
									wrapper.style.paddingBottom = "0.25em";
									wrapper.style.marginBottom = "-0.25em";
								}
							});

							return gsap.from(self.lines, {
								y: self.lines[0]?.offsetHeight * 1.25  ?? 60,
								autoAlpha: 0,
								stagger: 0.15,
								duration: 0.75,
								ease: "power2.out",
								delay: parseFloat((revealtext as HTMLElement).dataset.delay ?? "0"),
							});
						},
					});
				},
			});
		});
	});
</script>
