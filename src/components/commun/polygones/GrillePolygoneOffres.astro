  <PolygoneFlip frontText="Solution Web" backText="Back Texte" imageUrl="/src/assets/images/test.jpg" color="-web"/>
  <PolygoneFlip frontText="Sécurité" backText="Solution Web" color="-web" />
  <PolygoneStatic frontText="WeCERT" color="-web" />




  <PolygoneFlip frontText="Paie SILAE" backText="Back Texte" imageUrl="/src/assets/images/test.jpg" color="-metier"/>
  <PolygoneFlip frontText="Paie SILAE" imageUrl="/src/assets/images/test.jpg" color="-metier" />
  <PolygoneStatic frontText="Oddo" color="-metier" />
  
  
  <PolygoneFlip frontText="Android" videoUrl="/src/assets/videos/test.mp4" color="-app" />
  
  
  
  
  <PolygoneFlip frontText="Optimisation" backText="Back Texte" videoUrl="/src/assets/videos/test.mp4" color="-ia"/>
  <PolygoneFlip frontText="Analyse" backText="Intelligence Artificielle" color="-ia" />
  <PolygoneStatic frontText="Domaine" videoUrl="/src/assets/videos/test.mp4" color="-ia" />
  <PolygoneStatic frontText="Optimisation"  color="-ia" />

  <PolygoneStatic imageUrl="/src/assets/images/test2.jpg"/>
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
