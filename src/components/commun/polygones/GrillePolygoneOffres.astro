---
import PolygoneFlip from "./PolygoneFlip.astro";
import PolygoneStatic from "./PolygoneStatic.astro";
---

<div class="hex-grid -hidden" data-rows="3" data-cols="4" data-ratio="0.2" data-appearUp>

  <PolygoneFlip frontText="Solution Web" backText="Back Texte" imageUrl="/src/assets/images/test.png" color="-web"/>
  <PolygoneFlip frontText="Paie SILAE" backText="Back Texte" imageUrl="/src/assets/images/test.png" color="-metier"/>
  <PolygoneFlip frontText="Optimisation" backText="Back Texte" videoUrl="/src/assets/videos/test.mp4" color="-ia"/>


  <PolygoneFlip frontText="Sécurité" backText="Solution Web" color="-web" />
  <PolygoneFlip frontText="Analyse" backText="Intelligence Artificielle" color="-ia" />
  <PolygoneFlip frontText="Paie SILAE" imageUrl="/src/assets/images/test.png" color="-metier" />
  <PolygoneFlip frontText="Android" videoUrl="/src/assets/videos/test.mp4" color="-app" />
  
  <PolygoneStatic frontText="Optimisation"  color="-ia" />


  <PolygoneStatic frontText="Oddo" color="-metier" />
  <PolygoneStatic frontText="WeCERT" color="-web" />
  <PolygoneStatic frontText="Domaine" videoUrl="/src/assets/images/test.png" color="-ia" />

  <PolygoneStatic imageUrl="/src/assets/images/test2.jpg"/>
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
  <PolygoneStatic />
</div>

<style lang="scss" is:global>
  .hex-grid {
    display: grid;
    gap: 2px;
    margin-bottom:2px;
    /* colonnes et lignes définies par le script */

    svg {
      overflow: visible; // permet au stroke de ne pas être rogné par le viewport SVG
    }

    &.-hidden {
			visibility: hidden;	
		}
  }

</style>


<script>
function layoutGrid(grid: HTMLElement) {
  const COLS        = Number(grid.dataset.cols);
  const ROWS        = Number(grid.dataset.rows);
  const EMPTY_RATIO = Number(grid.dataset.ratio);

  const svgs = Array.from(grid.querySelectorAll<HTMLElement>('.polygone'));

  grid.style.gridTemplateColumns = `repeat(${COLS}, 1fr)`;
  grid.style.gridTemplateRows = `repeat(${ROWS}, auto)`;


  const positions: { row: number; col: number }[] = [];
  for (let row = 1; row <= ROWS; row++) {
    for (let col = 1; col <= COLS; col++) {
      positions.push({ row, col });
    }
  }

  // Mélange aléatoire des positions (Fisher-Yates)
  for (let i = positions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [positions[i], positions[j]] = [positions[j], positions[i]];
  }

  // Masque un nombre de polygones proportionnel à EMPTY_RATIO
  const visibleCount = Math.round(positions.length * (1 - EMPTY_RATIO));

  svgs.forEach((svg, i) => {
    if (i >= positions.length) { svg.style.display = 'none'; return; }
    const { row, col } = positions[i];
    svg.style.gridColumn = String(col);
    svg.style.gridRow    = String(row);
    svg.classList.remove('-visible', '-hidden');
    svg.classList.add(i < visibleCount ? '-visible' : '-hidden');
  });
}

// Attendre que la page soit complètement chargée
document.addEventListener("astro:page-load", () => {

  const grids = document.querySelectorAll<HTMLElement>('.hex-grid');
  
  // Appliquer la mise en page à chaque grille
  grids.forEach((grid) => {
    grid.classList.remove("-hidden");
    layoutGrid(grid);
  });


});
</script>