<style lang="scss" is:global>
  .hex-grid {
    display: grid;
    gap: 2px;
    margin-bottom:2px;
    /* colonnes et lignes définies par le script */

    svg {
      overflow: visible; // permet au stroke de ne pas être rogné par le viewport SVG
    }

    &.-hidden {
			visibility: hidden;	
		}
  }

  .polygone {
    transition: opacity 0.4s ease, filter 0.4s ease;

    &.-offre-active {
      //opacity: 1;
      //filter: none;
    }

    &.-offre-inactive:not(.polygone.-none) {
      //opacity: 0 !important;
      //filter: grayscale(1);
    }
  }

</style>


<script>
function layoutGrid(grid: HTMLElement) {
  const COLS        = Number(grid.dataset.cols);
  const ROWS        = Number(grid.dataset.rows);
  const EMPTY_RATIO = Number(grid.dataset.ratio);

  const svgs = Array.from(grid.querySelectorAll<HTMLElement>('.polygone'));

  grid.style.gridTemplateColumns = `repeat(${COLS}, 1fr)`;
  grid.style.gridTemplateRows = `repeat(${ROWS}, auto)`;


  const positions: { row: number; col: number }[] = [];
  for (let row = 1; row <= ROWS; row++) {
    for (let col = 1; col <= COLS; col++) {
      positions.push({ row, col });
    }
  }

  // Mélange aléatoire des positions (Fisher-Yates)
  for (let i = positions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [positions[i], positions[j]] = [positions[j], positions[i]];
  }

  // Masque un nombre de polygones proportionnel à EMPTY_RATIO
  const visibleCount = Math.round(positions.length * (1 - EMPTY_RATIO));

  svgs.forEach((svg, i) => {
    if (i >= positions.length) { svg.style.display = 'none'; return; }
    const { row, col } = positions[i];
    svg.style.gridColumn = String(col);
    svg.style.gridRow    = String(row);
    svg.classList.remove('-visible', '-hidden');
    svg.classList.add(i < visibleCount ? '-visible' : '-hidden');
  });
}




function layoutGridOffre(grid: HTMLElement) {
  const COLS = Number(grid.dataset.cols);
  const ROWS = Number(grid.dataset.rows);
  const DELAY = 0.035;

  grid.style.gridTemplateColumns = `repeat(${COLS}, 1fr)`;
  grid.style.gridTemplateRows = `repeat(${ROWS}, auto)`;

  // Pour chaque type de offres (-web, -metier, -app, -ia), on place les polygones sur la grille
  // dans l'ordre d'apparition, en remplissant ligne par ligne

  const typesOffres = [ '-none', '-web', '-metier', '-app', '-ia' , '-iot'];

  typesOffres.forEach((type) => {

    const svgs = Array.from(grid.querySelectorAll<HTMLElement>(`.polygone.${type}`));

    svgs.forEach((svg, index) => {
      const row = Math.floor(index / COLS) + 1;
      const col = (index % COLS) + 1;
      svg.style.gridColumn = String(col);
      svg.style.gridRow    = String(row);
      svg.dataset.delay = String(index * DELAY);
    });
  });
}



// Attendre que la page soit complètement chargée
document.addEventListener("astro:page-load", () => {

  const grids = document.querySelectorAll<HTMLElement>('.hex-grid');
  
  // Appliquer la mise en page à chaque grille
  grids.forEach((grid) => {
    if (grid.id === "grilleTagsOffres") return;
    grid.classList.remove("-hidden");
    layoutGrid(grid);
  });


  const gridOffres = document.querySelector("#grilleTagsOffres");
  if (gridOffres) {
    gridOffres.classList.remove("-hidden");
    layoutGridOffre(gridOffres);
  }








  // Réaction aux événements ScrollTrigger depuis Offres.astro
  document.addEventListener("offre:enter", (e) => {
    const { offre } = (e as CustomEvent).detail;
    // alert(`Offre entrée : ${offre}`);
    // Mettre en avant les polygones de l'offre active, masquer les autres
    document.querySelectorAll<HTMLElement>('#grilleTagsOffres .polygone').forEach((poly) => {
      if (poly.classList.contains(`-${offre}`)) {
        poly.classList.add('-offre-active');
        poly.classList.remove('-offre-inactive');
      } else {
        poly.classList.add('-offre-inactive');
        poly.classList.remove('-offre-active');
      }
    });
  });

  document.addEventListener("offre:leave", () => {
    // alert(`Offre quittée`);
    // Réinitialiser tous les polygones à l'état neutre
    document.querySelectorAll<HTMLElement>('#grilleTagsOffres  .polygone').forEach((poly) => {
      //poly.classList.remove('-offre-active', '-offre-inactive');
    });
  });

});
</script>