---
import Shape from "./Shape.astro";

interface Props {
  frontText?: string;
  backText?:  string;
  color?: string;
	videoUrl?: string;
	imageUrl?: string;
  addClass?: string;
}
const { frontText, backText = 'Back', videoUrl, imageUrl, color, addClass } = Astro.props;
---

<div class="polygone" addClass={addClass}>
  <Shape frontText={frontText} imageUrl={imageUrl} videoUrl={videoUrl} color={color}/>
</div>

<style lang="scss" is:global>
  .polygone {
    

    &.-visible {
      visibility: visible;
    }

    &.-hidden {
      visibility: hidden;
    }
  }
</style>
