---
interface Props {
	frontText?: string;
	backText?:  string;
	color?: string;
	videoUrl?: string;
	imageUrl?: string;
}
const { frontText, backText = 'Back', videoUrl, imageUrl, color } = Astro.props;
---

<div class={`polygon-shape ${color ?? ''}`}  style={imageUrl ? `background-image: url(${imageUrl});` : undefined}>
	{(!imageUrl || videoUrl) && (
		<span class="polygon-text">{frontText}</span>
	)}

	{videoUrl && (
		<video autoplay muted loop>
			<source src={videoUrl} type="video/mp4">
		</video>
	)}
</div>

<style lang="scss">

  .polygon-shape {
		position: relative;
		height: 128px;
		width: 110.851px;
		clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
		//   clip-path: path("M50% 0 Q54% 0 57% 4% L96% 22% Q100% 25% 100% 29% L100% 71% Q100% 75% 96% 78% L57% 96% Q54% 100% 50% 100% L43% 96% L4% 78% Q0% 75% 0% 71% L0% 29% Q0% 25% 4% 22% L43% 4% Q46% 0 50% 0 Z");
		
		display: flex;
		justify-content: center;
		align-items: center;

		background-size: cover;
		background-color: rgb(255, 255, 255, 0.10);
		backdrop-filter: blur(90%);
		outline: 2px dotted white;
		padding: 2px;

		.polygone-text {
			color: #2C5F8A;
			font-size: 12px;
			text-align: center;
		}

		video {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}

	.-web {
		background-color: rgb(15, 36, 230);
		color: white
	}

	.-metier {
		background-color: rgb(255, 162, 0);
		color: black
	}

	.-app {
		background-color: rgb(28, 168, 100);
		color: white
	}

	.-ia {
		background-color: rgb(38, 112, 208);
		color: white
	}

	.-objet {
		background-color: rgb(80, 171, 20);
		color: black
	}

	.-nothing {
		background-color: white;
	}

	.-stroke {
		border: 1px solid #2C5F8A;
	}

	.-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

</style>