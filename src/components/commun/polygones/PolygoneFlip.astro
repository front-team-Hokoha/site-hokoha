---
import Shape from "./Shape.astro";

interface FlipImage {
  src: string;
  alt: string;
}

interface Props {
  frontText?: string;
  backText?:  string;
  color?: string;
	videoUrl?: string;
	images?: FlipImage[];
}
const { frontText = 'Front', backText = 'Back', videoUrl, images = [], color } = Astro.props;
---

<div class={`polygone -flip jsFlipAuto  ${color}`} data-images={JSON.stringify(images)}>
  <div class="flip-inner">

    <!-- Face avant -->
    <div class="flip-face flip-front">
      <Shape frontText={frontText} imageUrl={images[0]?.src} alt={images[0]?.alt} color={color}/>
    </div>

    <!-- Face arrière -->
    <div class="flip-face flip-back">
      <Shape frontText={backText} videoUrl={videoUrl} imageUrl={images[1]?.src || images[0]?.src} alt={images[1]?.alt || images[0]?.alt} color={color}/>
    </div>

  </div>
</div>

<style lang="scss" is:global>
  .-flip {
    perspective: 800px;
    aspect-ratio: var(--polygone-aspect-ratio);
  }

  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    /* transition définie par le script */
  }

  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
</style>

<script>

  document.addEventListener("astro:page-load", () => {

    // ── Paramètres ────────────────────────────────────────────
    const FLIP_INTERVAL_MIN = 3;   // délai min entre deux flips (secondes)
    const FLIP_INTERVAL_MAX = 8;   // délai max entre deux flips (secondes)
    const FLIP_DURATION     = 0.5; // durée de l'animation de flip (secondes)
    const DELAY_MIN         = 2;   // délai de démarrage min (secondes)
    const DELAY_MAX         = 6;   // délai de démarrage max (secondes)
    // ──────────────────────────────────────────────────────────

    // Retourne 'X' ou 'Y' aléatoirement
    const randomAxis = () => (Math.random() < 0.5 ? 'X' : 'Y');

    // Retourne un délai aléatoire en ms entre [min, max] secondes
    const randomDelay = (min: number, max: number) =>
      (min + Math.random() * (max - min)) * 1000;

    type ImageItem = { src: string; alt?: string };

    document.querySelectorAll<HTMLElement>('.jsFlipAuto').forEach((cell) => {
      const inner = cell.querySelector<HTMLElement>('.flip-inner');
      const frontFace = cell.querySelector<HTMLElement>('.flip-front');
      const backFace = cell.querySelector<HTMLElement>('.flip-back');

      if (!inner || !frontFace || !backFace) return;

      const images = JSON.parse(cell.dataset.images || '[]') as ImageItem[];
      if (images.length === 0) return;

      // états
      let isFlipped = false;
      let currentAxis = randomAxis();
      let currentIndex = 0; // image actuellement visible

      backFace.style.transform = `rotate${currentAxis}(180deg)`;
      inner.style.transition = `transform ${FLIP_DURATION}s ease`;

      const frontImg = cell.querySelector<HTMLImageElement>('.flip-front img');
      const backImg  = cell.querySelector<HTMLImageElement>('.flip-back img');

      const get = (i: number) => images[((i % images.length) + images.length) % images.length];

      const setImage = (el: HTMLImageElement | null, item?: ImageItem) => {
        if (!el || !item) return;
        el.src = item.src;
        el.alt = item.alt || '';
      };

      const syncFaces = (activeIndex: number) => {
        setImage(frontImg, get(activeIndex));
        setImage(backImg, get(activeIndex + 1));
      };

      // initial
      syncFaces(currentIndex);

      const doFlip = () => {
        // prépare nouvel axe
        currentAxis = randomAxis();
        backFace.style.transform = `rotate${currentAxis}(180deg)`;

        // lance l'animation (basé sur l'état actuel)
        if (!isFlipped) {
          inner.style.transform = `rotate${currentAxis}(180deg)`; // front -> back
        } else {
          inner.style.transform = ``; // back -> front
        }

        // après l'animation, avance l'index et resynchronise les faces
        setTimeout(() => {
          currentIndex = (currentIndex + 1) % images.length;
          isFlipped = !isFlipped;
          syncFaces(currentIndex);
        }, FLIP_DURATION * 1000);
      };

      // boucle aléatoire
      const scheduleFlip = () => {
        const interval = randomDelay(FLIP_INTERVAL_MIN, FLIP_INTERVAL_MAX);
        setTimeout(() => {
          doFlip();
          scheduleFlip();
        }, interval);
      };

      setTimeout(scheduleFlip, randomDelay(DELAY_MIN, DELAY_MAX));
    });

  });
</script>