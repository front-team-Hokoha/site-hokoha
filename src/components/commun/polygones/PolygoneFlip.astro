---
import Shape from "./Shape.astro";

interface FlipImage {
  src: string;
  alt: string;
}

interface Props {
  frontText?: string;
  backText?: string;
  color?: string;
  videoUrl?: string;
  images?: FlipImage[];
}

const {
  frontText = "Front",
  backText = "Back",
  videoUrl,
  images = [],
  color,
} = Astro.props;
---

<div
  class={`polygone -flip jsFlipAuto ${color}`}
  data-images={JSON.stringify(images)}
>
  <div class="flip-inner">

    <!-- Face avant -->
    <div class="flip-face flip-front">
      <Shape
        frontText={frontText}
        imageUrl={images[0]?.src}
        alt={images[0]?.alt}
        color={color}
      />
    </div>

    <!-- Face arrière -->
    <div class="flip-face flip-back">
      <Shape
        frontText={backText}
        videoUrl={videoUrl}
        imageUrl={images[1]?.src || images[0]?.src}
        alt={images[1]?.alt || images[0]?.alt}
        color={color}
      />
    </div>

  </div>
</div>

<style lang="scss" is:global>
  .-flip {
    perspective: 800px;
    aspect-ratio: var(--polygone-aspect-ratio);
  }

  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {

    // ── Paramètres ─────────────────────────────
    const FLIP_INTERVAL_MIN = 3;
    const FLIP_INTERVAL_MAX = 8;
    const FLIP_DURATION = 0.5;
    const DELAY_MIN = 2;
    const DELAY_MAX = 6;
    // ───────────────────────────────────────────

    const randomDelay = (min: number, max: number) =>
      (min + Math.random() * (max - min)) * 1000;

    type ImageItem = {
      src: string;
      alt?: string;
    };

    const cleanupFns: (() => void)[] = [];

    document.querySelectorAll<HTMLElement>(".jsFlipAuto").forEach((cell) => {

      const inner = cell.querySelector<HTMLElement>(".flip-inner");
      const frontFace = cell.querySelector<HTMLElement>(".flip-front");
      const backFace = cell.querySelector<HTMLElement>(".flip-back");

      if (!inner || !frontFace || !backFace) return;

      const images = JSON.parse(
        cell.dataset.images || "[]"
      ) as ImageItem[];

      const hasImages = images.length > 0;

      let isFlipped = false;
      let currentIndex = 0;

      let scheduleTimeout: number;
      let flipTimeout: number;
      let startTimeout: number;

      backFace.style.transform = `rotateY(180deg)`;
      inner.style.transition = `transform ${FLIP_DURATION}s ease`;
      inner.style.transform = `rotateY(0deg)`;

      const frontImg =
        cell.querySelector<HTMLImageElement>(".flip-front img");

      const backImg =
        cell.querySelector<HTMLImageElement>(".flip-back img");

      const get = (i: number) => {
        if (!hasImages) return undefined;

        return images[
          ((i % images.length) + images.length) % images.length
        ];
      };

      const setImage = (
        el: HTMLImageElement | null,
        item?: ImageItem
      ) => {
        if (!el || !item) return;

        el.src = item.src;
        el.alt = item.alt || "";
      };

      const syncFaces = (activeIndex: number) => {
        if (hasImages) {
          setImage(frontImg, get(activeIndex));
          setImage(backImg, get(activeIndex + 1));
        }
      };

      syncFaces(currentIndex);

      const doFlip = () => {

        if (!isFlipped) {
          inner.style.transform = `rotateY(180deg)`;
        } else {
          inner.style.transform = `rotateY(0deg)`;
        }

        clearTimeout(flipTimeout);

        flipTimeout = window.setTimeout(() => {

          if (hasImages) {
            currentIndex = (currentIndex + 1) % images.length;
          }

          isFlipped = !isFlipped;

          syncFaces(currentIndex);

        }, FLIP_DURATION * 1000);
      };

      const scheduleFlip = () => {

        const interval = randomDelay(
          FLIP_INTERVAL_MIN,
          FLIP_INTERVAL_MAX
        );

        scheduleTimeout = window.setTimeout(() => {
          doFlip();
          scheduleFlip();
        }, interval);
      };

      startTimeout = window.setTimeout(() => {
        scheduleFlip();
      }, randomDelay(DELAY_MIN, DELAY_MAX));

      cleanupFns.push(() => {
        clearTimeout(scheduleTimeout);
        clearTimeout(flipTimeout);
        clearTimeout(startTimeout);
      });

    });

    document.addEventListener(
      "astro:before-swap",
      () => {
        cleanupFns.forEach((fn) => fn());
      },
      { once: true }
    );
  });
</script>