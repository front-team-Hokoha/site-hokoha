---
/**
 * PolygoneFlipProg — polygone deux faces piloté par scroll (section Offres/Programmes).
 *
 * Rendu : deux faces superposées (.flip-front / .flip-back) encapsulées dans un .flip-inner.
 * Chaque face utilise le composant Shape (SVG + texte/vidéo/image optionnels).
 *
 * Contrôle :
 *   - Écoute l'événement custom "offre:enter" (émis par Offres.astro via ScrollTrigger).
 *   - Si le polygone porte la classe `-{offre}` correspondante → doFlip() : révèle la face arrière.
 *   - Sinon → doUnflip() : revient à la face avant.
 *   - doFlip / doUnflip respectent un délai optionnel `data-delay` (secondes) pour les effets en cascade.
 *
 * Props :
 *   type        — classe CSS appliquée au wrapper (ex: "-dev", "-design")
 *   frontText   — texte face avant
 *   backText    — texte face arrière
 *   colorFront  — couleur de remplissage face avant (défaut: transparent)
 *   colorBack   — couleur de remplissage face arrière
 *   strokeType  — variante de trait SVG (défaut: "-none")
 *   videoUrl    — vidéo affichée sur la face arrière (optionnel)
 *   imageUrl    — image affichée sur la face arrière (optionnel)
 */
import Shape from "./Shape.astro";

interface Props {
  type?:  string;
  frontText?: string;
  backText?:  string;
  colorFront?: string;
  colorBack?: string;
	videoUrl?: string;
	imageUrl?: string;
	strokeType?: string
}
const { type, frontText = '', backText = '', videoUrl, imageUrl, colorFront = "transparent", colorBack, strokeType = "-none" } = Astro.props;
---

<div class={`polygone -flip jsFlipProg ${type}`}>
  <div class="flip-inner">

    <!-- Face avant -->
    <div class="flip-face flip-front">
      <Shape frontText={frontText}  color={colorFront} strokeType={strokeType}/>
    </div>

    <!-- Face arrière -->
    <div class="flip-face flip-back">
      <Shape frontText={backText} videoUrl={videoUrl} imageUrl={imageUrl} color={colorBack}/>
    </div>

  </div>
</div>

<script>

  document.addEventListener("astro:page-load", () => {
 

    // ── Paramètres ────────────────────────────────────────────
    const FLIP_DURATION     = 0.5; // durée de l'animation de flip (secondes)

    // ──────────────────────────────────────────────────────────


    document.querySelectorAll<HTMLElement>('.jsFlipProg').forEach((cell) => {
      const inner    = cell.querySelector<HTMLElement>('.flip-inner');
      const backFace = cell.querySelector<HTMLElement>('.flip-back');
      if (!inner || !backFace) return;

      // ── État local de la cellule ───────────────────────────
      // isFlipped : true = face arrière visible
      let isFlipped  = false;
      // currentAxis : axe utilisé pour le flip en cours
      //   → conservé pour l'animation retour afin de rester sur le même axe
      let currentAxis = 'X';

      // Initialisation : pose la face arrière pré-retournée sur l'axe courant
      // (backface-visibility:hidden empêche de la voir tant que l'inner n'est pas retourné)
      backFace.style.transform = `rotate${currentAxis}(180deg)`;

      // Durée de la transition CSS sur l'élément inner
      inner.style.transition = `transform ${FLIP_DURATION}s ease`;

      // ── Fonction de flip ────────────────────────────────────
      const doFlip = () => {
        if (!isFlipped) {
          // ── Front → Back ───────────────────────────────────
          // Met à jour la pré-rotation de la face arrière AVANT d'animer,
          // pour qu'elle soit déjà positionnée sur le bon axe
          backFace.style.transform = `rotate${currentAxis}(180deg)`;

          // Anime l'inner de 0° → 180° sur l'axe choisi, révélant la face arrière
          inner.style.transform = `rotate${currentAxis}(180deg)`;
          isFlipped = true;
        } else {
          // ── Back → Front ───────────────────────────────────
          // Retour sur le même axe que l'aller pour une animation cohérente
          inner.style.transform = '';
          isFlipped = false;
        
        }
      };

      // fonction pour forcer un retour à la face avant (sans changer d'axe)
      const doUnflip = () => {
        if (isFlipped) {
          inner.style.transform = '';
          isFlipped = false;
        }
      };

      // attache les fonctions de flip/unflip à l'instance DOM de la cellule pour pouvoir les appeler depuis l'extérieur
      (cell as any).doFlip   = () => setTimeout(doFlip,   parseFloat(cell.dataset.delay ?? '0') * 1000);
      (cell as any).doUnflip = () => setTimeout(doUnflip, parseFloat(cell.dataset.delay ?? '0') * 1000);
    });



    
    // Réaction aux événements ScrollTrigger depuis Offres.astro
    document.addEventListener("offre:enter", (e) => {
      const { offre } = (e as CustomEvent).detail;

      // Mettre en avant les polygones de l'offre active, masquer les autres
      document.querySelectorAll<HTMLElement>('.jsFlipProg').forEach((poly) => {
        if (poly.classList.contains(`-${offre}`)) {
          (poly as any).doFlip?.();
        } else {
          (poly as any).doUnflip?.();
        }
      });
    });
  
  });
</script>
