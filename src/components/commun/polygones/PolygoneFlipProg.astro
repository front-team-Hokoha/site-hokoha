---
import Shape from "./Shape.astro";

interface Props {
  type?: string;
  frontText?: string;
  backText?: string;
  colorFront?: string;
  colorBack?: string;
  videoUrl?: string;
  imageUrl?: string;
  strokeType?: string;
}

const {
  type,
  frontText = "",
  backText = "",
  videoUrl,
  imageUrl,
  colorFront = "transparent",
  colorBack,
  strokeType = "-none",
} = Astro.props;
---

<div class={`polygone -flip jsFlipProg ${type}`}>
  <div class="flip-inner">

    <!-- Face avant -->
    <div class="flip-face flip-front">
      <Shape
        frontText={frontText}
        color={colorFront}
        strokeType={strokeType}
      />
    </div>

    <!-- Face arrière -->
    <div class="flip-face flip-back">
      <Shape
        frontText={backText}
        videoUrl={videoUrl}
        imageUrl={imageUrl}
        color={colorBack}
      />
    </div>

  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {

    const FLIP_DURATION = 0.5;

    const cleanupFns: (() => void)[] = [];

    document.querySelectorAll<HTMLElement>(".jsFlipProg").forEach((cell) => {

      const inner =
        cell.querySelector<HTMLElement>(".flip-inner");

      const backFace =
        cell.querySelector<HTMLElement>(".flip-back");

      if (!inner || !backFace) return;

      let isFlipped = false;
      let currentAxis = "X";

      let flipTimeout: number;
      let unflipTimeout: number;

      backFace.style.transform =
        `rotate${currentAxis}(180deg)`;

      inner.style.transition =
        `transform ${FLIP_DURATION}s ease`;

      inner.style.transform = `rotateX(0deg)`;

      const isMobile = window.innerWidth <= 1024;

      if (isMobile) {
        isFlipped = true;
        inner.style.transform = `rotateX(180deg)`;
      }

      const doFlip = () => {

        if (!isFlipped) {

          backFace.style.transform =
            `rotate${currentAxis}(180deg)`;

          inner.style.transform =
            `rotate${currentAxis}(180deg)`;

          isFlipped = true;
        }
      };

      const doUnflip = () => {

        if (isFlipped) {

          inner.style.transform =
            `rotate${currentAxis}(0deg)`;

          isFlipped = false;
        }
      };

      (cell as any).doFlip = () => {

        clearTimeout(flipTimeout);

        flipTimeout = window.setTimeout(() => {
          doFlip();
        }, parseFloat(cell.dataset.delay ?? "0") * 1000);
      };

      (cell as any).doUnflip = () => {

        clearTimeout(unflipTimeout);

        unflipTimeout = window.setTimeout(() => {
          doUnflip();
        }, parseFloat(cell.dataset.delay ?? "0") * 1000);
      };

      if (isMobile) {

        (cell as any).doFlip = () => {};
        (cell as any).doUnflip = () => {};
      }

      cleanupFns.push(() => {
        clearTimeout(flipTimeout);
        clearTimeout(unflipTimeout);
      });
    });

    // ── EVENTS ─────────────────────────────────

    const enterHandler = (e: Event) => {

      const { offre } = (e as CustomEvent).detail;

      document
        .querySelectorAll<HTMLElement>(".jsFlipProg")
        .forEach((poly) => {

          if (poly.classList.contains(`-${offre}`)) {
            (poly as any).doFlip?.();
          } else {
            (poly as any).doUnflip?.();
          }
        });
    };

    const leaveHandler = () => {

      document
        .querySelectorAll<HTMLElement>(".jsFlipProg")
        .forEach((poly) => {
          (poly as any).doUnflip?.();
        });
    };

    document.addEventListener(
      "offre:enter",
      enterHandler
    );

    document.addEventListener(
      "offre:leave",
      leaveHandler
    );

    // ── CLEANUP ────────────────────────────────

    document.addEventListener(
      "astro:before-swap",
      () => {

        document.removeEventListener(
          "offre:enter",
          enterHandler
        );

        document.removeEventListener(
          "offre:leave",
          leaveHandler
        );

        cleanupFns.forEach((fn) => fn());

      },
      { once: true }
    );
  });
</script>