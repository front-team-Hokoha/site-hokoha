---
import { Image } from "astro:assets";

const { imagePath, altText } = Astro.props;

// Import synchrone des images
const images = import.meta.glob(
  "/src/assets/images/**/*.{jpeg,jpg,png,gif}",
  {
    eager: true,
    import: "default"
  }
);

// Récupération de l’image correspondant au path
const image = images[imagePath];

if (!image) {
  throw new Error(`Image not found: ${imagePath}`);
}
---

<!-- Attention : ne pas nommer le composant Image mais ImageSok lors de l'importation pour ne pas créer de conflit avec le composant Image nati -->
<Image
  src={image}
  alt={altText}
  class="sokImage"
/>

<style lang="scss">
  .sokImage {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>