---
// Composant Astro
import { Image } from "astro:assets";

// imagePath : chemin de l'image
// altText : texte alternatif
const { imagePath, altText } = Astro.props;

// Import synchrone des images
const images = import.meta.glob(
  "/src/assets/images/**/*.{jpeg,jpg,png,gif}",
  {
    eager: true,
    import: "default"
  }
);

// Récupération de l’image correspondant au path
const image = images[imagePath];

if (!image) {
  throw new Error(`Image not found: ${imagePath}`);
}
---

<!-- Attention : nommez le composant "ImageSok" lors de l'importation pour ne pas créer de conflit avec le composant Image natif -->
<Image
  src={image}
  alt={altText}
  class="sokImage"
  width="360px"
  height="395.5px"
/>

<style lang="scss">
  .sokImage {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
  }
</style>