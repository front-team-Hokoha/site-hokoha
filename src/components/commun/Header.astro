---
import PictoLight from "./PictoLight.astro";

// ATTENTION : En cas de changement des liens, modifier les Navbar Desktop et Mobile


// Images


---

<!-- HEADER -->
<header class="layout-app__header oka-appbar oka-darkMode oka-surface sok-header">
	<div class="oka-appbar__row">
		<div class="oka-appbar__left" style="flex-shrink:1;">
			<a href="/">
			</a>

			<PictoLight />

		</div>

    <div class="oka-appbar__right -hiden">
      <div class="sok-toggle">
        <i class="fa-thin fa-bars"></i>
      </div>

		<!-- Navigation Desktop -->
      <nav class="sok-navbar">
			<div class="sok-navbar__items">
				<a class="oka-h -xs" href={import.meta.env.BASE_URL} aria-label="lien vers la page d'accueil">
					Accueil
				</a>

				<a class="oka-h -xs" href={`${import.meta.env.BASE_URL}methodologie`} aria-label="lien vers la page méthodologie">
					Méthodologie
				</a>

				<a class="oka-h -xs" href={`${import.meta.env.BASE_URL}realisations`} aria-label="lien vers la page réalisations">
					Réalisations
				</a>

				<a class="oka-h -xs" href={`${import.meta.env.BASE_URL}equipe`} aria-label="lien vers la page équipe">
					Équipe
				</a>
			</div>

			<a class="oka-bt sok-contact__btn" href={`${import.meta.env.BASE_URL}contact`} aria-label="lien vers la page contact">
				<div class="oka-bt__lbl">
					Contact
				</div>
			</a>
      </nav>
    </div>
  </div>
</header>

<div class="sok-navbar__mobile-container oka-darkMode oka-surface">
	<div class="sok-navbar__mobile-overlay"></div>
	
	<!-- Navigation mobile -->
	<nav class="sok-navbar__mobile">
		<div class="oka-spacer -xxl" aria-hidden="true"></div>
		<div class="oka-spacer -xxl" aria-hidden="true"></div>

		<div class="sok-navbar__items">
			<a class="oka-h -lg" href={import.meta.env.BASE_URL} aria-label="lien vers la page d'accueil">
				Accueil
			</a>

			<a class="oka-h -lg" href={`${import.meta.env.BASE_URL}methodologie`} aria-label="lien vers la page méthodologie">
				Méthodologie
			</a>

			<a class="oka-h -lg" href={`${import.meta.env.BASE_URL}realisations`} aria-label="lien vers la page réalisations">
				Réalisations
			</a>

			<a class="oka-h -lg" href={`${import.meta.env.BASE_URL}equipe`} aria-label="lien vers la page équipe">
				Équipe
			</a>
		</div>

		<div class="oka-spacer -xxl" aria-hidden="true"></div>

		<a class="oka-bt -lg sok-contact__btn" href={`${import.meta.env.BASE_URL}contact`} aria-label="lien vers la page contact">
			<div class="oka-bt__lbl">
				Contact
			</div>
		</a>

		<div class="oka-spacer -xxl" aria-hidden="true"></div>
	</nav>
</div>

<!-- emêche l'animation du header en JavaScript  -->
<!-- 
<div class="oka-appWrap -fluid" data-appeardown data-delay="0">
