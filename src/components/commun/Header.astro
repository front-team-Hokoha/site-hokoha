---
import logokoha2 from '../../assets/images/logokoha-2.svg';
---

<!-- HEADER -->
<header class="layout-app__header  oka-appbar oka-darkMode oka-surface sok-header">

	<div class="oka-appbar__row ">

		<div class="oka-appbar__left" style="flex-shrink:1;"> 
			<a href="/">
				<img class="sok-logokoha" src={logokoha2.src} alt="logo Hokoha">
			</a>
		</div>

		<div class="oka-appbar__right -hiden">
			<div class="sok-toggle">
				menu
			</div>

			<nav class="sok-navbar">

				<div class="oka-spacer -xl -spacing" aria-hidden="true"></div>

				<div class="sok-navbar__items">
					<a class="oka-h" href="/" aria-label="lien vers la page d'accueil">Accueil</a>
			
					<a class="oka-h" href="/methodologie" aria-label="lien vers la page méthodologie">Méthodologie</a>
				
					<a class="oka-h" href="/realisations" aria-label="lien vers la page réalisations">Réalisations</a>
				
					<a class="oka-h" href="/equipe" aria-label="lien vers la page équipe">Équipe</a>
				</div>
				
				<div class="oka-spacer -xl -spacing" aria-hidden="true"></div>
				
				<a class="oka-bt sok-contact__btn" href="/contact" aria-label="lien vers la page contact">
					<div class="oka-bt__lbl">Contact</div>
				</a>

				<div class="oka-spacer -md -spacing" aria-hidden="true"></div>
			</nav>
		</div>
</div>

</header>

<!-- emêche l'animation du header en JavaScript  -->
<!-- <div class="oka-appWrap -fluid" data-appeardown data-delay="0">
</div> -->

<style lang="scss">
  @use "../../styles/oka-design-system/0-abstracts/breakpoints/breakpoints" as *;  
	
  // Retrait du transform : empêche l'affichage du menu sur mobile/tablet	
  .oka-appWrap {
		transform: none !important;
		z-index: 99;
	}

	// Masque certains oka-spacer
	.-spacing {
		@include breakpoint(md) {
			display: none
		}
	}
	
	// Empêche de scroller lorsque la menu est ouvert
	body.no-scroll {
		overflow: hidden;
	}

	// ===== Header =====
	.sok-header {
		position:  fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 99;
		width: 100%;
		background-color: var(--oka-color-layer-floor-0); // var(--oka-color-neutral-50);
		margin:  0 0 0 0;
		padding: 0.5rem 1rem;
	}

	.sok-logokoha{
		height: 3.125rem;
	}

	// ==== Navbar ====
	.sok-toggle  {
		display: block;
		cursor: pointer;

		@include breakpoint(md) {
			display: none;
			visibility: hidden;
		}
	}

	.sok-navbar {
		position: absolute;
		top: 4rem;
		left: 0;
		right: 0;
		z-index: -1;
		width: 100%;
		padding: 0rem 2rem;
		background-color: var(--oka-color-layer-floor-0);
		border-radius: 0 0 10px 10px;
		box-shadow: 3px 3px 3px 3px rgba(0, 0, 0,0.1);
		transform: translateY(-150%);
		transition: all .5s ease-out;

		&.active {
			transform: translateY(0);
		}

		@include breakpoint(md) {
			position: static;
			display: flex;
			align-items: center;
			gap: 2rem;
			z-index: 1; // important por pouvoir cliquer sur les liens
			width: auto;
			padding: 0;
			background-color: transparent;
			box-shadow: none;
			transform: translateY(0);
			transition: none;
		}

		&__items {
			display: flex;
			flex-direction: column;
			gap: .5rem;

			@include breakpoint(md) {
				flex-direction: row;
				gap: 2rem;
			}

			a,
			a:visited {
				color: unset;
				text-decoration: none;
				padding: 0;
			}
		}
	}
</style>


<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener('astro:page-load', () => {
		const toggle = document.querySelector('.sok-toggle');
		const navbar = document.querySelector('.sok-navbar');
		const navLinks = document.querySelectorAll('.sok-navbar__items a');
	
		// Affiche le menu au clique
		toggle?.addEventListener('click', () => {
			navbar?.classList.toggle('active');
			// TODO: êmpche le scrool à l'ouverture du menu
			// document.body.classList.toggle('no-scroll');
		});
	
		// Ajoute ou retire des classes en fonction du viewport
		toggleClasses();
		window.addEventListener('resize', toggleClasses);
		fixedHeader();

	
		function toggleClasses() {
			const isDesktop = window.innerWidth >= 1024;
	
			navLinks.forEach(navLink => {
				navLink.classList.toggle('-lg', !isDesktop);	
				navLink.classList.toggle('-xs', isDesktop);	
				// navLink.classList.toggle('-secondary', isDesktop);	
			})
		}

		// ===== GSAP ===== 
		// Permet d'afficher et masquer le header lors du scroll
		// Influence les performances du site ?
		function fixedHeader() {
			console.log('gsap');
			
			const showAnim = gsap.from('.sok-header', { 
				yPercent: -100,
				paused: true,
				duration: 0.5,
				ease: "power2"
			}).progress(1);

			ScrollTrigger.create({
				start: "top top",
				end: "max",
				onUpdate: (self) => {
					self.direction === -1 ? showAnim.play() : showAnim.reverse()
				}
			});
		}
	});
</script>

