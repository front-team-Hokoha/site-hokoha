<style lang="scss">
	@use "../../styles/oka-design-system/0-abstracts/breakpoints/breakpoints" as *;

	// Retrait du transform : empêche l'affichage du menu sur mobile/tablet
	// .oka-appWrap {
	// 	transform: none !important;
	// 	z-index: 99;
	// }

	// ==== Base ====
	a,
	a:visited {
		color: unset;
		text-decoration: none;
		padding: 0;
	}

	i {
		font-size: 1.5rem;
	}

  // ===== Header =====
	.sok-header {
		position: fixed;
		top: 1rem;
		left: 1rem;
		right: 1rem;
		z-index: 99;

		width: auto;
		margin: 0;
		padding: 2.5rem 1rem;

		background-color: var(--oka-color-layer-floor-0);
		border-radius: 0.5rem;

		// Zone invisible au-dessus du header rétracté 
		// évite de perdre le hover dans le gap
		&::before {
			content: '';
			position: absolute;
			z-index: -1;
			top: -80px;
			left: 0;
			right: 0;
			height: 200px;
			//background: red;
		}

		&:hover {
			transform: translateY(0) !important;
			transition: transform 0.3s ease;
		}
	}


  // ==== Navbar Mobile ====
	.sok-toggle {
		display: block;
		cursor: pointer;

		@include breakpoint(md) {
			display: none;
			visibility: hidden;
			user-select: none;
		}
	}

	.sok-navbar__mobile-container {
		position: relative;
		
		@include breakpoint(md) {
			display: none;
			visibility: hidden;
			user-select: none;
		}
		
		.sok-navbar__mobile-overlay {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 10;
			display: none;
			width: 100%;
			height: 100vh;
			// background-color: var(--oka-color-layer-overlay);
			background-color:  var(--oka-color-bg-minimal);

			backdrop-filter: blur(4px);

			&.-visible {
				display: block;
			}
		}

		.sok-navbar__mobile {
			position: fixed;
			top: 5.5rem;
			left: 1rem;
			right: 1rem;
			z-index: 50;
			
			padding: 0 4rem;
			background-color: var(--oka-color-layer-floor-0);
			border-radius: 0 0 0.5rem 0.5rem;
			// box-shadow: 3px 3px 3px 3px rgba(0, 0, 0,0.1);
			//transform: translateY(-125%);
			transition: max-height 0.35s ease-out;

			max-height : 0; // Permet de ne pas faire bug le transform translateY
			overflow: hidden;

			&.active {
				max-height: 800px;
			}

			.sok-navbar__items {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
		}
	}

  // ==== Navbar Desktop ====
	.sok-navbar {
		display: none;
		align-items: center;
		gap: 2rem;

		@include breakpoint(md) {
			display: flex;
		}

		.sok-navbar__items {
			display: flex;
			flex-direction: row;
			gap: 2rem;
		}
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("astro:page-load", () => {
		const toggle = document.querySelector(".sok-toggle");
		const icon = toggle?.querySelector(".fa-thin");

		const navbar = document.querySelector(".sok-navbar__mobile");
		const navLinks = document.querySelectorAll(".sok-navbar__items a");
		const menuOverlay = document.querySelector('.sok-navbar__mobile-overlay');

		const body = document.body;	
		const $body = document.querySelector('body');
		if (!$body) return;	
	
		let scrollPosition = 0;

		toggle?.addEventListener("click", () => {
			// Affiche le menu mobile au clique du toggle
			navbar?.classList.toggle("active");

			// Changer l'icône au clique
			if (icon?.classList.contains('fa-bars')) {
				icon?.classList.replace('fa-bars', 'fa-times');
			} else {
				icon?.classList.replace('fa-times', 'fa-bars');
			}

			// bloquer le scroll lors de l'utilisation du menu sur mobile
			const enableNoScroll = function() {
				//alert('enableNoScroll')
				scrollPosition = window.pageYOffset;
				// console.trace(scrollPosition);
				$body.style.overflow = 'hidden';
				$body.style.position = 'fixed';
				$body.style.top = `-${scrollPosition}px`;
				$body.style.width = '100%';
				//
				body.classList.add('u-noscroll');
			};
	
			const disableNoScroll = function() {
				//alert('disableNoScroll')
				$body.style.removeProperty('overflow');
				$body.style.removeProperty('position');
				$body.style.removeProperty('top');
				$body.style.removeProperty('width');
				window.scrollTo(0, scrollPosition);
				//
				body.classList.remove('u-noscroll');
			};

			if (!menuOverlay?.classList.contains('-visible')) {
				menuOverlay?.classList.toggle('-visible');
				enableNoScroll();
				console.log("l'overlay est visible");

			} else {
				menuOverlay?.classList.toggle('-visible');
				disableNoScroll();
				console.log("l'overlay est invisible");
			}
    });
	 

	// GSAP
	// Permet d'afficher et masquer le header lors du scroll
	// Influence les performances du site ?
	fixedHeader();

	function fixedHeader() {
		const SCROLL_OFFSET = 480;    // px depuis le top avant que le header puisse se masquer
		const SCROLL_THRESHOLD = 50;  // px scrollés dans la même direction avant action
		const HIDE_Y = -88;          // px vers le haut lors du retrait (négatif = vers haut)

		let lastScrollY = 0;
		let delta = 0;

		const showAnim = gsap
			.from(".sok-header", {
				y: HIDE_Y,
				paused: true,
				duration: 0.5,
				ease: "power2",
			})
			.progress(1);

		ScrollTrigger.create({
			start: "top top",
			end: "max",
			onUpdate: (self) => {
				const currentY = self.scroll();
				const diff = currentY - lastScrollY;
				lastScrollY = currentY;

				if (currentY < SCROLL_OFFSET) {
					showAnim.play();
					delta = 0;
					return;
				}

				delta += diff;

				if (delta > SCROLL_THRESHOLD) {
					showAnim.reverse();
					delta = 0;
				} else if (delta < -SCROLL_THRESHOLD) {
					showAnim.play();
					delta = 0;
				}
			},
		});
	}
	});

	// Ajoute ou retire des classes en fonction du viewport
	// toggleClasses();
	// window.addEventListener('resize', toggleClasses);

	// function toggleClasses() {
	// 	const isDesktop = window.innerWidth >= 1024;
	
	// 	navLinks.forEach(navLink => {
	// 		navLink.classList.toggle('-lg', !isDesktop);
	// 		navLink.classList.toggle('-xs', isDesktop);
	// 		// navLink.classList.toggle('-secondary', isDesktop);
	// 	})
	// }	
</script>