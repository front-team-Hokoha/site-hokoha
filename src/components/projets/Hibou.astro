---
// ===== GLobalStyles =====
import GlobalStyles from '../../components/commun/GlobalStyles.astro';

// ===== Composants de la page =====
import MediaWrapper from '../../components/commun/MediaWrapper.astro';
import VideoSok from '../../components/commun/VideoSok.astro';
import ImageSok from '../../components/commun/ImageSok.astro';
import Marquee from '../../components/commun/marquee/Marquee.astro';
import MarqueeItem from '../../components/commun/marquee/MarqueeItem.astro';

// ===== Composants d'animations =====
import RevealText from '../../animations/RevealText.astro';

// ===== Fichiers Markdown =====
// import * as paragrapheHero from "../../contenus/projets/hibou/paragraphe-hero.md"
// import * as paragraphe from "../../contenus/projets/hibou/paragraphe.md"
---

<!-- ===== Hero ===== -->
<div class="oka-appWrap -fluid oka-lightMode oka-surface">
  <section class="_ctnr-inline"> 

    <div class="flex-grid">

      <div class="col col-16">
        <div class="oka-spacer -xxl" aria-hidden="true"></div>
        <div class="oka-spacer -xxl" aria-hidden="true"></div>

        <div class="oka-cols -two">
          <div class="sok-content-wrapper -first">
            <RevealText>
              <h1 class="oka-h -xl">22 - Hibou</h1>
            </RevealText>
          </div>

          <div class="sok-content-wrapper -second">
            <p class="sok-paragraph oka-text -lg">
              Lorem ipsum dolor sit amet consectetur. Commodo dui diam in maecenas sed tincidunt fames bibendum varius. Arcu dolor a amet risus platea lacus.
            </p>
          </div>
        </div>

      </div>

    </div>

  </section>
</div>

<!-- Contenu -->
<div class="oka-appWrap -fluid oka-lightMode oka-surface">
  <section class="_ctnr-inline">
    <div class="oka-spacer -xl" aria-hidden="true"></div>
    
    <div class="flex-grid">
      <div class="col col-16">
        <MediaWrapper ratio="16/9" radius="sm">
          <!-- <ImageSok imagePath="/src/assets/images/realisations/Hibou/mockup.jpg" altText="photo de l'équipe Hokoha" /> -->
          <VideoSok srcVideo="/src/assets/videos/realisations/Hibou/Hibou.mp4" typeVideo="mp4" thumbnail="/src/assets/images/realisations/Hibou/thumbnail.png"/>
        </MediaWrapper>

        <div class="oka-spacer -xl" aria-hidden="true"></div>
        <!-- <div class="oka-spacer -xl" aria-hidden="true"></div> -->

        <div class="sok-projet__container">
          <ul class="sok-projet__infos-list">
            <li class="sok-projet__infos-item">
               <h3 class="oka-h -sm">Type</h3>
               <p class="oka-text">Logiciel métier</p>
            </li>

            <li class="sok-projet__infos-item">
               <h3 class="oka-h -sm">Secteur</h3>
               <p class="oka-text">Sécurité</p>
            </li>

            <li class="sok-projet__infos-item">
               <h3 class="oka-h -sm">Prestations</h3>
               <p class="oka-text">UI/UX, développement</p>
            </li>

            <li class="sok-projet__infos-item">
               <h3 class="oka-h -sm">Année</h3>
               <p class="oka-text">20XX</p>
            </li>     
          </ul>

          
          <!-- Contenus -->
          <div class="sok-projet__content-container">
            <div class="oka-spacer -xl -spacing" aria-hidden="true"></div>


            <div class="sok-projet__content-wrapper">
               <div class="sok-projet__content">
                  <h3 class="oka-h -sm">Contexte</h3>

                  <p class="oka-text -md sok-paragraph">
                     Lorem ipsum dolor sit amet consectetur. Blandit tincidunt id mattis at sit donec sagittis commodo aenean. Ullamcorper odio pharetra consectetur fusce et orci facilisi nullam. Morbi velit amet mauris feugiat et elementum gravida. Purus pellentesque dictumst quis faucibus pellentesque. Faucibus nibh sed felis sem nibh augue malesuada erat. In vitae diam arcu at orci et amet.
                  </p>
               </div>

               <MediaWrapper ratio="3/2" radius="sm">
                  <ImageSok imagePath="/src/assets/images/realisations/Hibou/mockup-1.jpg" altText="photo de l'équipe Hokoha" />
               </MediaWrapper>
            </div>

            <div class="oka-spacer -xl" aria-hidden="true"></div>
            <!-- <div class="oka-spacer -xl" aria-hidden="true"></div> -->

            <div class="sok-projet__content-wrapper">
               <div class="sok-projet__content">
                  <h3 class="oka-h -sm">Fonctionnalités</h3>

                  <div class="sok-projet__text-wrapper">
                     <p class="oka-text -md sok-paragraph">
                        Lorem ipsum dolor sit amet consectetur. At ut enim eu purus nisl. Enim accumsan nisi quam ante. Facilisi egestas amet consectetur neque duis. Varius risus suspendisse orci enim risus lorem commodo vitae vestibulum. Praesent semper morbi vel purus dictumst turpis pellentesque enim nec. Morbi sollicitudin velit donec velit arcu fringilla venenatis ipsum.
                     </p>
   
                     <div class="oka-spacer -md" aria-hidden="true"></div>
   
                     <p class="oka-text -md sok-paragraph">
                        Lorem ipsum dolor sit amet consectetur. Vehicula pellentesque sit molestie sed. Ut semper nunc nisl elementum consequat felis magna malesuada aliquam. A parturient eget molestie morbi interdum. Ultrices leo mattis consequat leo id. Sed nibh sed feugiat nulla odio turpis elementum sed. Ac interdum venenatis gravida lorem viverra velit ante auctor morbi. Ornare amet ac purus nisl etiam eget. Fermentum elementum amet fermentum aliquet pellentesque.
                     </p>
                  </div>
               </div>

               <div class="sok-projet__media-wrapper">
                  <MediaWrapper ratio="3/2" radius="sm">
                     <ImageSok imagePath="/src/assets/images/realisations/Hibou/mockup-1.jpg" altText="photo de l'équipe Hokoha" />
                  </MediaWrapper>

                  <MediaWrapper ratio="3/2" radius="sm">
                     <ImageSok imagePath="/src/assets/images/realisations/Hibou/mockup-2.jpg" altText="photo de l'équipe Hokoha" />
                  </MediaWrapper>
               </div>
            </div> 
          </div>
        </div>

        <div class="oka-spacer -xl -spacing" aria-hidden="true"></div>
        <div class="oka-spacer -xl -spacing" aria-hidden="true"></div>
      </div>
    </div>
    
    <div class="oka-spacer -xl" aria-hidden="true"></div>
    <div class="oka-spacer -xl" aria-hidden="true"></div>
  </section>
</div>



