<!-- === GobalStyles === -->
<GlobalStyles/>

<style lang="scss">
   @use "../../styles/oka-design-system/0-abstracts/breakpoints/breakpoints" as *;

   :root {
      --col-size: calc(100dvw / 16);
   }


   .oka-appWrap {

      @include breakpoint(xs) {
         padding: 0 2rem;
      }

      @include breakpoint(lg) {
         padding: 0 calc(var(--col-size) * 1);
      }
   }

   .-spacing {
      @include breakpoint(sm) {
         display: none;
      }
   }

   // Base
   .oka-h.-sm {
      padding: 0;
   }

   .sok-paragraph {
      padding: 0;
      
      @include breakpoint(md) {
         // max-width: calc(var(--col-size) * 8);
         width: 100%;
      }
   }

   // Titreet paragraphe d'arrivé
   .sok-content-wrapper {

      // Titre du projet
      &.-first {
         height: auto;
         align-items: end;
      }

      // Paragraphe générale du projet
      &.-second {
         text-align: justify;

         @include breakpoint(sm) {
            justify-content: end;
            text-align: end;
         }
      }
   }

   // Détails du projet
   .sok-projet__container {
      display: flex;
      flex-direction: column;
      width: 100%;

      @include breakpoint(sm) {
         flex-direction: row;
      }

      // Informations du projet
      .sok-projet__infos-list {
         display: flex;
         flex-direction: column;
         gap: 1rem;
         box-sizing: border-box;
         width: 100%;
         margin: 0;
         padding: 0;
         list-style-type: none;

         @include breakpoint(sm) {
            flex: 0 0 calc(var(--col-size) * 4);
         }

         // .sok-projet__infos-item {
         //    display: flex;
         //    align-items: center;
         //    flex-wrap: wrap;
         //    gap: 4rem;
         // }
      }

      // Contenu du projet
      .sok-projet__content-wrapper {
         width: 100%;

         @include breakpoint(sm) {
            flex: 0 0 calc(var(--col-size) * 10);
         }

         .sok-projet__content {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding-bottom: 3rem;
   
            .sok-paragraph {
               margin-bottom: 0; 
               text-align: justify;

               @include breakpoint(md) {
                  width: 100%;
                  max-width: calc(var(--col-size) * 9);
                  text-align: start;
               }
            }
         }
   
         .sok-projet__media-wrapper {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            
            @include breakpoint(md) {
               flex-direction: row;
            }
         }
      }
   }
</style>