---
// ===== Componsants de la page =====
import CardSavoirFaire from "./savoir-faire/CardSavoirFaire.astro"
import CardContainer from "./savoir-faire/CardContainer.astro";
// import Grid from "../../components/commun/grid.astro";
// ===== Composants d'animations =====
import Revealtext from "../../animations/RevealText.astro";

// ==== Import du fichier Markdown
import * as titreSavoirFaire from "../../contenus/accueil/savoir-faires/titre-savoir-faire.md"
import * as paragrapheSavoirFaire from "../../contenus/accueil/savoir-faires/paragraphe-savoir-faire.md"
---
<!-- <div class="oka-appWrap -fluid oka-darkMode oka-surface"> -->
<div class="oka-appWrap -fluid">
  <section class="sok-sf" id="sok-sf">
  
    <div class="hgo-snap oka-appWrap -fluid">
      <section class="_ctnr-inline sok-savoirfaire">
        <div class="flex-grid ">

          <div class="col col-16">
            <div class="flex-grid sok-savoirfaire__wrapper">
              <div class="col col-1" aria-hidden="true"></div>
              
              <div class="col col-14 sok-savoirfaire__content-container">
                <div class="flex-grid -center">
    
                  <div class="col col-7 sok-savoirfaire__content" aria-hidden="true">
                    <div class="sok-savoirfaire__titles">
                      <span class="oka-text -sm -strong">NOTRE SAVOIR-FAIRE</span>
                      
                      <div class="oka-spacer -sm" aria-hidden="true"></div>
                      
                      <Revealtext>
                        <titreSavoirFaire.Content />
                      </Revealtext>
              
                      <!-- <div class="sok-t-paragraph">
                        <paragrapheSavoirFaire.Content />
                      </div> -->
                    </div>
                  </div>
    
                  <div class="col col-7 sok-savoirfaire__quote-wrapper" aria-hidden="true">
                    <div class="oka-spacer -xl -spacing" aria-hidden="true"></div> 
    
                    <div class="sok-savoirfaire__quote">
                      <span class="oka-text -strong -lg">“Notre seul but est de faire bien”</span>
        
                      <p class="oka-text -sm">Ernő Rubik - Inventeur du Rubik’s Cube</p>
    
                      <div class="oka-spacer -xl -spacing" aria-hidden="true"></div> 
                    </div>
                  </div>
                  
                </div>
              </div>
              
            </div>
          </div>      
          
        </div>    
      </section>
    </div>
    
    <div class="oka-appWrap -fluid">  
      <section class="sok-savoirfaire__cards">
        <div class="sok-card-container">
          <CardSavoirFaire />
        </div>
      </section>    
    </div>
  </section>

</div>


<style lang="scss">
  @use "../../styles/oka-design-system/0-abstracts/breakpoints/breakpoints" as *;  
  .-spacing {
    @include breakpoint(md) {
      display: none;
    }
  }
  
  .sok-savoirfaire {
    
    &__wrapper {
      background-color: var(--oka-color-layer-floor-0);

      @include breakpoint(md) {
        min-height: 35vh;
        align-items: center;
        border: 1px solid var(--oka-color-bd-minimal);
      }
    }
    
    &__quote-wrapper {
      @include breakpoint(md) {
        display: flex;
        justify-content: end;
        align-items: end;
      }
    }
  }

  // Container des cartes
  .sok-card-container {
    @include breakpoint(md) {
      display: flex;
      // overflow: hidden;
    }
  }
</style>