---
import Offres from "./Offres.astro";
import GrilleOffres from "../../components/commun/polygones/GrillePolygoneOffres.astro";
import GrilleVierge from "../../components/commun/polygones/GrillePolygoneVierge.astro";
import Revealtext from "../../animations/RevealText.astro";
import PolygoneMask from "../commun/polygones/PolygoneMask.astro"
import RevealMask from "../../animations/RevealMask.astro";
---

<section class="flex-grid sok-hero oka-darkMode">
   

   <div class="sok-hero_ray" aria-hidden="true"></div>


   <div class="sok-8ptgrid" aria-hidden="true"></div>
   <div class="sok-8ptgrid -secondary" aria-hidden="true"></div>

   <div class="col col-1"></div>
   <div class="col col-7">
      <div class="oka-spacer  -lg" aria-hidden="true"></div>
      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      
      <Revealtext>
         <img class="sok-logokoha" src="/src/assets/images/logokoha.svg" alt="logo Hokoha">
      </Revealtext>

      <Revealtext>
         <h1 class="oka-h -xxl">Développement Informatique sur-mesure.</h1>
      </Revealtext>

      <div class="oka-spacer  -md" aria-hidden="true"></div>
      <p class="oka-text -lg">
         Lorem ipsum dolor sit amet consectetur. Urna fringilla dui quis a vitae
         cras. Dui nec amet mauris tempor interdum facilisi eget.
      </p>

      <div class="oka-spacer  -md" aria-hidden="true"></div>
  
      <button class="oka-bt -lg -solid   ">
         <div class="oka-bt__lbl">call to action</div>
         <div class="oka-bt__ico"><i class="fa fa-arrow-right"></i></div>
        <div class="oka-spinner"></div>
      </button>

      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
   
      <!-- ===== Offres ===== -->
      <!-- <Offres /> -->

      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      <!-- <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      <div class="oka-spacer  -xxl" aria-hidden="true"></div>
      <div class="oka-spacer  -xxl" aria-hidden="true"></div> -->

   </div>

   <div class="col col-1"></div>
   <div class="col col-5">
      <div class="hexa">
            <div class="oka-spacer  -lg" aria-hidden="true"></div>

         <GrilleVierge />
         <GrilleOffres />
         <GrilleVierge /><!-- -->
      </div>
   </div>

</section>

<style lang="scss">


   .sok-hero_ray{
      position:fixed;
      top:0;
      width:14dvw;
      height:100dvh;
      //transform: rotate(14deg);
      //transform-origin: top right ;

      background-image: 
         radial-gradient(
            circle at center,
            var(--sok-color-bg-blue-800) 0%,
            var(--sok-color-bg-blue-800) 40%,
            var(--sok-color-bg-strong) 60%
         )
         //,
         // linear-gradient(
         //    var(--sok-color-bg-strong),
         //    var(--sok-color-bg-blue-600) 46dvh,
         //    var(--sok-color-bg-blue-500) 50dvh,
         //    var(--sok-color-bg-blue-600) 56dvh,
         //    var(--sok-color-bg-strong) 80dvh
         // )
         ;
      
      background-attachment: fixed;


      // mix-blend-mode: normal;
      // mix-blend-mode: multiply;
      mix-blend-mode: screen;
      // mix-blend-mode: overlay;
      // mix-blend-mode: darken;
      // mix-blend-mode: lighten;
       mix-blend-mode: color-dodge;
      // mix-blend-mode: color-burn;
      // mix-blend-mode: hard-light;
      // mix-blend-mode: soft-light;
      // mix-blend-mode: difference;
      // mix-blend-mode: exclusion;
      // mix-blend-mode: hue;
      // mix-blend-mode: saturation;
      // mix-blend-mode: color;
      // mix-blend-mode: luminosity;
      // mix-blend-mode: plus-lighter;
      // mix-blend-mode: plus-darker;

   }



   .sok-hero {
      position:relative;

      // margin:1rem;
      // border-radius : 2rem;

      background-color: var(--sok-color-bg-strong);
      // background-image: linear-gradient(
      //    var(--sok-color-bg-strong),
      //    var(--sok-color-bg-blue-800) 30dvh,
      //    var(--sok-color-bg-blue-700) 34dvh,
      //    var(--sok-color-bg-blue-600) 38dvh,
      //    var(--sok-color-bg-blue-500) 42dvh,
      //    var(--sok-color-bg-blue-600) 46dvh,
      //    var(--sok-color-bg-blue-700) 50dvh,
      //    var(--sok-color-bg-blue-800) 54dvh,
      //    var(--sok-color-bg-strong) 80dvh
      //    );

      background-image: linear-gradient(
         var(--sok-color-bg-blue-500) ,
         var(--sok-color-bg-blue-600) 8dvh,
         var(--sok-color-bg-blue-700) 16dvh,
         var(--sok-color-bg-blue-800) 24dvh,
         var(--sok-color-bg-strong) 50dvh
         );
      background-attachment: fixed;
     
   }


   .hexa {
      position:sticky;
      top: 0;
   }

   .sok-8ptgrid {
      position: fixed;
      inset: 0;
      width: 3dvw;
      height: 60dvh;
      pointer-events: none;
      background-image: repeating-linear-gradient(
         to bottom,
         rgba(255, 255, 255, 0.05) 0px,
         rgba(255, 255, 255, 0.05) 8px,
         transparent 8px,
         transparent 16px
      );

      &.-secondary {
         width: 4dvw;
         height: 80dvh;
      }
   }

   .sok-mask-container {
      position: relative;
      overflow: hidden;
      width: 400px;
      height: 400px;
      border: 2px solid red;
      /* Background de couleur blanc obligatoire pour ne pas voir l'image de fond */
      background: white;
   }

   .sok-mask-img {
      background-image: url("/src/assets/images/test2.jpg");
      position: absolute;
      inset: 0;
      mix-blend-mode: screen; 
      z-index: 99;
   }

   .sok-mask {
      position: absolute;
      inset: 0;
   }

   // .mask-form {
   //    position: absolute;
   //    width: 300px;
   //    height: 100px;
   //    background-color: #000;
   // }
</style>


<script>
	import { gsap } from "gsap";
	import { SplitText } from "gsap/SplitText";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(SplitText, ScrollTrigger);
</script>