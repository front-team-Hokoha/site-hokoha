---
const savoirFaires = Object.values(import.meta.glob("../../../contenus/accueil/savoir-faires/*.md", { eager: true }));


/* 
   Liste de cartes de savoir-faire. 
   Chaque carte est positionnée de manière sticky, 
   avec un top qui s'ajuste dynamiquement en fonction de la hauteur cumulée des titres des cartes précédentes.
*/
---
{savoirFaires.map((savoirFaire) => (
   <article class="sok-card">
      {/* corriger ça plus tard */}
      <div class="content flex-grid">
         <div class="oka-spacer  -md" aria-hidden="true"></div>

         <div class="col col-1"></div>

         <div class="col col-13">
         <div class="sok-card__card-content">
            <span class="oka-data -md -strong">
               {savoirFaire.frontmatter.subtitle}
            </span>
            <div class="oka-spacer -sm" aria-hidden="true"></div>

            <h3 class="oka-h -lg">
               {savoirFaire.frontmatter.title}
            </h3>
         </div>

         <div class="sok-card__card-text" set:html={savoirFaire.rawContent()}>
            {/* <savoirFaire.Content /> */}
         </div>


         <div class="oka-spacer -md" aria-hidden="true"></div>
         
         <button class="oka-bt -outlined">
           {/* <div class="oka-bt__ico"><i class="fa fa-heart"></i></div> */}
           <div class="oka-bt__lbl">En savoir plus</div>
           <div class="oka-spinner"></div>
         </button>

         </div>
         

         <div class="oka-spacer  -md" aria-hidden="true"></div>
      </div>

   </article>
  
))}


<style lang="scss">
   .oka-text {
      color: red;
   }

  .sok-card {
      position: sticky;
      top: 8rem;
   
      background-color: var(--oka-color-layer-floor-0);

      border: 1px solid var(--oka-color-bd-minimal);
      border-radius: .5rem;
   }

   .contenu {
      max-width : 400px;
   }
  
</style>

<script>
  function updateStickyTops() {
    const cards = document.querySelectorAll<HTMLElement>('.oka-savoir-faire__card');
    const BASE_TOP_REM = 8;
    const rootFontSize = parseFloat(getComputedStyle(document.documentElement).fontSize);
    let cumulativeOffset = 0;

    cards.forEach((card) => {
      card.style.top = `calc(${BASE_TOP_REM}rem + ${cumulativeOffset}px)`;
      const header = card.querySelector<HTMLElement>('.oka-savoir-faire__card-content');
      if (header) {
        cumulativeOffset += header.getBoundingClientRect().height;
      }
    });
  }

  updateStickyTops();

  const ro = new ResizeObserver(updateStickyTops);
  document.querySelectorAll('.oka-savoir-faire__card-content').forEach((el) => ro.observe(el));


  //  ajouter une class pour chaque carte pour les animations au scroll
	function addClassToCards() {
    const cards = document.querySelectorAll<HTMLElement>('.oka-savoir-faire__card');

		cards.forEach((card, index) => {
				card.classList.add(`card-${index + 1}`)
		});
	}

	addClassToCards();
</script>

