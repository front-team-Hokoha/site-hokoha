---
// ===== Composants utilisés =====
import ImageSok from "../../../commun/ImageSok.astro";
import MediaWrapper from "../../../commun/MediaWrapper.astro";

// ===== Fichiers Markdown =====
const savoirFaires = Object.values(import.meta.glob("../../../../contenus/accueil/savoir-faires/cartes/*.md", { eager: true }));
---

{
  savoirFaires.map((savoirFaire) => (
    <article class="sok-card">

        <div class="sok-card__container">
          <div class="sok-card__side-text">
            <span class="oka-text -lg -strong">{savoirFaire.frontmatter.num}</span>

            <h3 class="oka-h -md">{savoirFaire.frontmatter.tag}</h3>
          </div>

          <div class="sok-card__wrapper">
            <div class="sok-card__content-wrapper">
              <div class="oka-spacer -inline -md" aria-hidden="true"></div>

              <div class="sok-card__content">
                <h3 class="oka-h -lg" set:html={savoirFaire.frontmatter.title}></h3>

                {/* rawContent permet d'afficher le contenu du .md sans ajouter de balise html dans le DOM */}
                <div class="sok-t-paragraph">
                  <p class="oka-text -md">
                    {savoirFaire.rawContent()}
                  </p>
                </div>

                <div class="oka-spacer -md" aria-hidden="true" />

                <button class="oka-bt -outlined">
                  <div class="oka-bt__lbl">En savoir plus</div>
                </button>
              </div>
            </div>

            <figure class="sok-card__image-wrapper">
              <img src={savoirFaire.frontmatter.src}alt={savoirFaire.frontmatter.alt}/>
            </figure> 
          </div>
        </div>

    </article>
  ))
}

<style lang="scss">
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .flex-grid {
    // height: 100%;
  }

  .sok-card {
    max-width: 1008px;
    overflow: hidden;
    margin-right: -1px;
    background-color: var(--oka-color-layer-floor-0);
    border: 1px solid var(--oka-color-bd-minimal);

    &__container {
      display: flex;
      flex-direction: column;
      width: max-content;
      // height: 100%;

      .sok-card__side-text {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 4.5rem;
        width: 100%;
        padding: 1rem;
        border-bottom: 1px solid var(--oka-color-bd-minimal);

        // & > * {
        //   writing-mode: sideways-lr;
        // }
      }

      .sok-card__wrapper {
        display: flex;
        width: 100%;
        overflow: hidden;
      }

      .sok-card__content-wrapper {
        display: flex;

        .sok-card__content {
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: start;
          max-width: 500px;

          // À AMÉLIORER
          .oka-h {
            min-width: 500px;
            width: 100%;
          }

          .sok-t-paragraph {
            max-width: 440px;
          }
        }
      }

      // Image des cartes
      .sok-card__image-wrapper {
        min-width: 400px;
        max-width: 400px;
        aspect-ratio: 1/1;
        margin: 0;
      }
    }
  }
</style>

{/* ===== GSAP ===== */}
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelector(".sok-card-container");

    if (!cards) return;

    const totalHeight = cards.scrollHeight;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".sok-savoirefaire",
        start: "top top", 
        end: () => `+=${totalHeight}`,
        scrub: true,
        pin: true,
        anticipatePin: 1,
        markers: true
      }
    });

    const sokCards = document.querySelectorAll('.sok-card');

    sokCards.forEach((sokCard, i) => {
      const rightContent = sokCard.querySelector(".sok-card__wrapper");

      tl.to(rightContent, {
        height: 0,
        duration: 1
      }, i);
    });


    // Ancien code
    // const screenWidth = window.innerWidth;
    // const scrollDistance = totalWidth - screenWidth;

    // gsap.to(cards, {
    //   x: -scrollDistance,
    //   scrollTrigger: {
    //     trigger: ".sok-savoirefaire",
    //     start: "top top",
    //     end: () => `+=${totalWidth}`,
    //     scrub: 1,
    //     pin: true,
    //     anticipatePin: 1,
    //     invalidateOnRefresh: true,
    //     // snap: 1 / (cards.children.length - 1),
    //     // markers: true,
    //   }
    // });
  });
</script>
