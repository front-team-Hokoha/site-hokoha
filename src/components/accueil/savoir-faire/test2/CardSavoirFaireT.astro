---
// ===== Composants utilisés =====
// import ImageSok from "../../commun/ImageSok.astro";
// import MediaWrapper from "../../commun/MediaWrapper.astro";

// ===== Fichiers Markdown =====
const savoirFaires = Object.values(import.meta.glob("../../../../contenus/accueil/savoir-faires/cartes/*.md", { eager: true }));
---

{savoirFaires.map((savoirFaire) => (
    <article class="sok-card">

        {/* <div class="sok-card__container">
          <div class="sok-card__side-text">
            <h3 class="oka-h -md">{savoirFaire.frontmatter.tag}</h3>

            <span class="oka-data -lg -strong">{savoirFaire.frontmatter.num}</span>
          </div>
        </div> */}

        <div class="sok-card__wrapper">
          <div class="sok-card__content">

            <h3 class="oka-h -lg" set:html={savoirFaire.frontmatter.title}></h3>

            {/* rawContent permet d'afficher le contenu du .md sans ajouter de balise html dans le DOM */}
            <div class="sok-t-paragraph">
              <p class="oka-text -md">
                {savoirFaire.rawContent()}
              </p>
            </div>

            <div class="oka-spacer -md" aria-hidden="true" />

            <button class="oka-bt -outlined">
              <div class="oka-bt__lbl">En savoir plus</div>
            </button>
          </div>

          <figure class="sok-card__image-wrapper">
            <img src={savoirFaire.frontmatter.src}alt={savoirFaire.frontmatter.alt}/>
          </figure> 


          {/* remplacer content=img par ça : à améliorer en cs d'utilisation */}
          {/* Englober l'image dans le composant MediaWrapper et remplacer img par ImageSok */}

          {/* <MediaWrapper ratio="1/1">
            <ImageSok imagePath={savoirFaire.frontmatter.src} altText={savoirFaire.frontmatter.alt} />
            <img src={savoirFaire.frontmatter.src} alt={savoirFaire.frontmatter.alt} />
          </MediaWrapper> */}
        </div>

    </article>
  ))
}

<style lang="scss">
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sok-card {
    overflow: hidden;
    min-width: 80%;
    max-width: 80%;
    padding: 4rem 2rem;
    // background-color: var(--oka-color-layer-floor-0);
    background-color: var(--oka-color-underground);
    border-right: 1px solid var(--oka-color-bd-minimal);

     /* .sok-card__side-text {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--oka-color-bd-minimal);

        & > * {
          writing-mode: sideways-lr;
        }
      } */

    &__wrapper {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;

      .sok-card__content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: start;
        max-width: 500px;

        // À AMÉLIORER
        .oka-h {
          min-width: 500px;
          width: 100%;
        }

        .sok-t-paragraph {
          max-width: 440px;
        }
      }

      // Image des cartes
      .sok-card__image-wrapper {
        width: 100%;
        height: 30dvh;
        margin: 0;
      }
    }
  }
</style>