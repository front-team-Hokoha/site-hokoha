---
// ===== Composants utilisés =====
// import ImageSok from "../../commun/ImageSok.astro";
// import MediaWrapper from "../../commun/MediaWrapper.astro";

// ===== Fichiers Markdown =====
const savoirFaires = Object.values(import.meta.glob("../../../contenus/accueil/savoir-faires/cartes/*.md", { eager: true }));
---

{savoirFaires.map((savoirFaire) => (

  <article class="sok-card">
    <div class="flex-grid sok-card__container">

      {/* bandeau */}
      <div class="col col-4 side-wrapper">
        <div class="sok-card__side">
          <h3 class="oka-h -md">{savoirFaire.frontmatter.tag}</h3>

          <span class="oka-data -lg -strong">
            {savoirFaire.frontmatter.num}
          </span>
        </div>
      </div>

      <div class="col col-4 card-content-wrapper">
        <div class="flex-grid -h">

          <div class="sok-card__content-wrapper">

            <div class="col col-4 texts-wrapper">
              <div class="sok-card__content">
                {/* <div class="oka-spacer -md" aria-hidden="true" /> */}

                <h3 class="oka-h -xl" set:html={savoirFaire.frontmatter.title} />

                <div class="sok-t-paragraph">
                  <p class="oka-text -md">{savoirFaire.rawContent()}</p>
                </div>

                <div class="oka-spacer -md" aria-hidden="true" />

                <button class="oka-bt -outlined">
                  <div class="oka-bt__lbl">En savoir plus</div>
                </button>
              </div>
            </div>

            <div class="col col-4 image-wrapper">
              <div class="oka-spacer -xl -spacing" aria-hidden="true" />

              <figure class="sok-card__image-inner">
                <img src={savoirFaire.frontmatter.src} alt={savoirFaire.frontmatter.alt} />
              </figure> 

              {/* <div class="oka-spacer -md" aria-hidden="true" />  */}
            </div>

          </div>

        </div>
      </div>

    </div>
  </article>

  
))}

<style lang="scss">
  @use "../../../styles/oka-design-system/0-abstracts//breakpoints/breakpoints" as *;  
  
  .-spacing {
    @include breakpoint(md) {
      display: none;
    }
  }

  .-h {
    height: 100%;
  }

  .sok-card {
    margin-bottom: -1px;
    border: 1px solid var(--oka-color-bd-minimal);
    
    .sok-card__container {
      gap: 0;

      @include breakpoint(md) {
        min-height: 65vh;
        overflow: hidden;
      }

      // ===== Bandeau latéral =====
      .sok-card__side {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid var(--oka-color-bd-minimal);
    
        @include breakpoint(md) {
          flex-direction: column;
          height: 100%;
          padding: 2rem 1rem;          
          border-right: 1px solid var(--oka-color-bd-minimal);
          border-bottom: none;
        }

        & > * {
          writing-mode: horizontal-tb;

          @include breakpoint(md) {
            writing-mode: sideways-lr;
          }
        }

        .oka-h {
          padding: 0
        }
      }
  
      // ===== Contenu des cartes =====
      .sok-card__content-wrapper {
        padding: 1rem;

        @include breakpoint(sm) {
          // padding: 20rem;
          padding: 2rem;
        }

        @include breakpoint(md) {
          display: flex;
        }

        .sok-card__content {
    
          .oka-h {
            width: 100%;
            // max-width: 740px;
            max-width: 605px;

            @include breakpoint(lg) {
              // min-width: 740px;
            }
          }
    
          .sok-t-paragraph {
            max-width: 480px;
            text-align: justify;

            @include breakpoint(md) {
              text-align: start;
              min-width: 480px;
            }
          }
        }

        // ===== Image =====
        .sok-card__image-inner {
          width: 100%;
          height: clamp(225px, 25vh, 300px);
          margin: 0;

          @include breakpoint(md) {
            height: 100%;
          }
      
          & img {
            width: 100%;
            height: 100%;
            object-fit: cover;
          }
        }
      }
    }

  }
</style>


<script>
document.addEventListener('astro:page-load', () => {
  const sideWrappers = document.querySelectorAll('.side-wrapper');
  const cardContentWrappers = document.querySelectorAll('.card-content-wrapper');
  const textsContentWrappers = document.querySelectorAll('.texts-wrapper');
  const imageWrappers = document.querySelectorAll('.image-wrapper');
  
  updateClasses();
  // Surveille si la fenêtre est redimensionnée
  window.addEventListener('resize', updateClasses)

  function updateClasses() {
    const viewportWidth = window.innerWidth;
    
    if (viewportWidth >= 1024) {
      resizeLargeDevice();
    } else if ((viewportWidth >= 768) && (viewportWidth < 1024)) {
      resizeMediumDevice();
    } else {
      resizeSmallDevice();
    }
  }

  // Retirer les classes précédentes
  function removeAllClasses(el: Element) {
    el.classList.remove('col-8', 'col-1', 'col-13', 'col-9', 'col-4');
  }

  // Viewport : inférieur à 768px
  function resizeSmallDevice() {
    [sideWrappers, cardContentWrappers, textsContentWrappers, imageWrappers]
    .forEach(group => group.forEach(el => {
      removeAllClasses(el);
      el.classList.add('col-4');
    }));
  }

  // Viewport : supérieur ou égale à 768px et inférieur à 1024px
  function resizeMediumDevice() {
    [sideWrappers, cardContentWrappers, textsContentWrappers, imageWrappers]
    .forEach(group => group.forEach(el => {
      removeAllClasses(el);
      el.classList.add('col-8');
    }));
  }

  // Viewport : supérieur ou égale à 1024px
  function resizeLargeDevice() {
    [sideWrappers, cardContentWrappers, textsContentWrappers, imageWrappers]
    .forEach(group => group.forEach((el, i) => {
      removeAllClasses(el);     
    }));

    sideWrappers.forEach(sideWrapper => sideWrapper.classList.add('col-1'));
    cardContentWrappers.forEach(cardContentWrapper => cardContentWrapper.classList.add('col-13'));
    textsContentWrappers.forEach(textsContentWrapper => textsContentWrapper.classList.add('col-9'));
    imageWrappers.forEach(imageWrapper => imageWrapper.classList.add('col-4'));
  }    
})
</script>



