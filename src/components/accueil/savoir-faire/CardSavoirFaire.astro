---
const savoirFaires = Object.values(import.meta.glob("../../../contenus/accueil/savoir-faires/cartes/*.md", { eager: true }));
---

{
  savoirFaires.map((savoirFaire) => (
    <article class="sok-card">

        <div class="sok-card__wrapper">
          <div class="sok-card__side-text">
            <h3 class="oka-h -md">{savoirFaire.frontmatter.tag}</h3>

            <span class="oka-data -lg -strong">{savoirFaire.frontmatter.num}</span>
          </div>

          <div class="sok-card__content-wrapper">
            <div class="oka-spacer -inline -md" aria-hidden="true"></div>

            <div class="sok-card__content">
              <h3 class="oka-h -lg" set:html={savoirFaire.frontmatter.title}></h3>

              {/* rawContent permet d'afficher le contenu du .md sans ajouter de balise html dans le DOM */}
              {/* enblober la balise p dans un sok-t-paragraph */}
              <div class="sok-t-paragraph">
                <p class="oka-text -md">
                  {savoirFaire.rawContent()}
                </p>
              </div>

              <div class="oka-spacer -md" aria-hidden="true" />

              <button class="oka-bt -outlined">
                <div class="oka-bt__lbl">En savoir plus</div>
              </button>
            </div>
          </div>

          {/* en cas d'utilisation d'une image */}
          {/* Englober l'image dans le composant MediaWrapper et remplacer img par ImageSok */}

          {/* <figure class="sok-card__content-img">
            <img
              src={savoirFaire.frontmatter.src}
              alt={savoirFaire.frontmatter.alt}
            />
          </figure> */}
        </div>
    </article>
  ))
}

<style is:global>
  .pin-spacer {
    background-color: var(--sok-color-underground);
  }
</style>

<style lang="scss">
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .flex-grid {
    height: 100%;
  }

  .sok-card {
    // À AMÉLIORER
    max-width: 640px;

    height: 360px;
    overflow: hidden;
    margin-right: -1px;
    background-color: var(--oka-color-layer-floor-0);
    border: 1px solid var(--oka-color-bd-minimal);
    // border-radius: 0.5rem;

    &__wrapper {
      display: flex;
      height: 100%;

      .sok-card__side-text {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        width: 4.5rem;
        padding: 1rem 0;
        border-right: 1px solid var(--oka-color-bd-minimal);

        & > * {
          writing-mode: sideways-lr;
        }
      }

      .sok-card__content-wrapper {
        display: flex;

        .sok-card__content {
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: start;

          // À AMÉLIORER
          .oka-h {
            min-width: 542px;
          }

          .sok-t-paragraph {
            max-width: 440px;
          }
        }
      }

      // Image des cartes
      // .sok-card__content-img {
      //   width: 45%;
      //   height: 100%;
      //   margin: 0;
      // }
    }
  }
</style>

{/* ===== GSAP ===== */}
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelector(".sok-card-container");

    if (!cards) return;

    const totalWidth = cards.scrollWidth;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".sok-savoirefaire",
        start: "top -5%", // Commence un peu plus tôt
        end: () => `+=${totalWidth}`,
        scrub: true,
        pin: true,
        anticipatePin: 1,
      }
    });

    const sokCards = document.querySelectorAll('.sok-card');

    sokCards.forEach((sokCard) => {
      const rightContent = sokCard.querySelector(".sok-card__content-wrapper");

      tl.to(rightContent, {
        width: 0,
        duration: 1
      });
    })


    // Ancien code
    // const screenWidth = window.innerWidth;
    // const scrollDistance = totalWidth - screenWidth;

    // gsap.to(cards, {
    //   x: -scrollDistance,
    //   scrollTrigger: {
    //     trigger: ".sok-savoirefaire",
    //     start: "top top",
    //     end: () => `+=${totalWidth}`,
    //     scrub: 1,
    //     pin: true,
    //     anticipatePin: 1,
    //     invalidateOnRefresh: true,
    //     // snap: 1 / (cards.children.length - 1),
    //     // markers: true,
    //   }
    // });
  });
</script>
