---
import Offres from "./Offres.astro";
import GrilleIntro from "../../components/commun/polygones/GrillePolygoneIntro.astro";
import GrilleVierge from "../../components/commun/polygones/GrillePolygoneVierge.astro";
import Revealtext from "../../animations/RevealText.astro";
import RevealMask from "../../animations/RevealMask.astro";
---




<section class="sok-hero">
   

  


   <div class="flex-grid">
      <div class="col col-1"></div>
      <div class="col col-8">
         <!-- <div class="oka-flex  -center-top -gap-xs"> -->
          
            <div class="oka-spacer  -xxl" aria-hidden="true"></div>
            <Revealtext>
               <img class="sok-logokoha"  src="/src/assets/images/logokoha-dark.png" alt="logo Hokoha">
            </Revealtext>

            <Revealtext>
               <h1 class="oka-h -xl">Développement Informatique sur-mesure.</h1>
            </Revealtext>

            <div class="oka-spacer  -sm" aria-hidden="true"></div>
            <p class="oka-text -lg">
               Lorem ipsum dolor sit amet consectetur. Urna fringilla dui quis a vitae
               cras. Dui nec amet mauris tempor interdum facilisi eget.
            </p>

            <div class="oka-spacer  -lg" aria-hidden="true"></div>
            <!-- <GrilleIntro /> -->
 


         <!-- </div> -->

         <!-- <div class="oka-spacer  -xxl" aria-hidden="true"></div>
         <div class="oka-spacer  -xxl" aria-hidden="true"></div> -->
      
         
      </div>
    
      <div class="col col-6">
         <!-- <GrilleIntro cols="2" /> -->
      </div>
      
   </div>

   <div class="flex-grid">
      <div class="col col-1">
      
      </div>
      <div class="col col-14"><GrilleIntro cols="7" /></div>
   </div>

</section>

<style lang="scss">

   .sok-hero {
      position:relative;
      z-index: 1;

      margin:0;
      border-radius : var(--sok-radius-section)  var(--sok-radius-section) 0 0;

      background-color: var(--sok-color-surface);
      
   }

   .sok-logokoha{
      width: auto;
      height: 56px;
   }

</style>


<script>
	import { gsap } from "gsap";
	import { SplitText } from "gsap/SplitText";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(SplitText, ScrollTrigger);
</script>