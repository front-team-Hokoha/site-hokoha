<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {


   
    const OFFRES = document.querySelectorAll<HTMLElement>("[data-offre]");
    const OFFRE_SCROLL_STEP = 400; // Distance de scroll virtuelle entre chaque déclenchement (en px)

    ScrollTrigger.create({
      trigger: "#offres",
      start: "top top",

      // +1 pour donner au dernier item son espace complet avant le dépingage
      end: `+=${(OFFRES.length + 1) * OFFRE_SCROLL_STEP}`,
      
      pin: true,  // ===== Pin #offres jusqu'à #finOffres =====
      //pinSpacing: false,
      //markers: true,

    });


    OFFRES.forEach((offre, index) => {

      const offreId = offre.dataset.offre;
      const sectionOffre = offre.closest(".sok-offre") as HTMLElement;
      
      ScrollTrigger.create({
        trigger: offre,
        //markers: true,
        

        // Décale virtuellement le trigger suivant OFFRE_SCROLL_STEP:
        // item 0 , item 1 → 400px plus tard, item 2 → 800px plus tard…
        start: `top+=${index * OFFRE_SCROLL_STEP}px 60%`,
        end: `bottom+=${index * OFFRE_SCROLL_STEP + OFFRE_SCROLL_STEP}px 60%`,
       
        onEnter: () => {

          offre.classList.add("-active");
          offre.classList.add("-display");
          sectionOffre.classList.add("-active");

          console.log("Entré dans l'offre :", offreId);
          document.dispatchEvent(
            new CustomEvent("offre:enter", { detail: { offre: offreId } })
          );
        },
        onEnterBack: () => {
          // const offreId = offre.dataset.offre;
          offre.classList.add("-active");
          sectionOffre.classList.add("-active");

          document.dispatchEvent(
            new CustomEvent("offre:enter", { detail: { offre: offreId } })
          );
        },

        onLeave: () => {
          // const offreId = offre.dataset.offre;
          offre.classList.remove("-active");
          sectionOffre.classList.remove("-active");

          document.dispatchEvent(
            new CustomEvent("offre:leave", { detail: { offre: offreId } })
          );
        },

        onLeaveBack: () => {
          // const offreId = offre.dataset.offre;
          offre.classList.remove("-active");
          sectionOffre.classList.remove("-active");
          
          document.dispatchEvent(
            new CustomEvent("offre:leave", { detail: { offre: offreId } })
          );
        },
      });
    });

  });
</script>


<style lang="scss">
  
  .sok-offres,
  .sok-section {
      position:relative;
      z-index: 1;
      margin:0;
      border-radius : 0 0  var(--sok-radius-section)  var(--sok-radius-section);
      background-color: var(--oka-color-layer-floor-0);

  }


  .sok-offres__intro {
    background-color: var(--oka-color-layer-floor-0);
  }

  .oka-h {
    padding: 0;
  }



  .sok-offre {

    position: absolute;
    width: 100%;
    min-height: 100dvh;
    

    &.-background {
      background: var(--oka-color-layer-floor-0);
    }


    &__item {

      --sokOffre-item-height: 4rem;
      

      height: var(--sokOffre-item-height);

      flex-shrink:0;
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 1rem 0;
      overflow: hidden;

      opacity: 0.3;
      translate: 0rem 0px;

      pointer-events: none;


      &[data-offre="web"] {
        position: absolute;
        top: calc(0 * var(--sokOffre-item-height));
      }
      &[data-offre="metier"] {
        position: absolute;
        top: calc(1 * var(--sokOffre-item-height));
      }
       &[data-offre="app"] {
        position: absolute;
        top: calc(2 * var(--sokOffre-item-height));
      }
      &[data-offre="ia"] {
        position: absolute;
        top: calc(3 * var(--sokOffre-item-height));
      }
      &[data-offre="iot"] {
        position: absolute;
        top: calc(4 * var(--sokOffre-item-height));
      }


      &.-display {
        opacity: 1;
        pointer-events: all;
        translate: 0px 0px;
      }


      .-active & {
        //flex-direction: row-reverse;
        opacity: 1;
        translate: 8px 0px;
        
      }

      & > .sok-arrow {
        margin-left: -2rem;
        zoom:0.5;
        // transition: margin .15s ease-in-out;
        opacity: 0;
        transition: margin .15s cubic-bezier(.63,.78,.25,1);

        .-active & {
          margin-left: -1.05rem;
          margin-right:1rem;
          opacity: 1;
        }


      }

    }
    &__detail {
      padding-right: 2rem;
      opacity: 0;
      transition: opacity 1s ease 1.35s;


      .-active & {
        opacity: 1;
      }


      p {
        padding-top:8rem;
        border-top:2px solid var(--oka-color-fg);
      }
    }  
  }


</style>