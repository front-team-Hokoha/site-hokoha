---
const { addClass, srcImage, altImage } = Astro.props;
// ===== Composants de la page =====
import PolygoneStatic from "../commun/polygones/PolygoneStatic.astro";
---

<a href="#">
   <article class={`oka-projet oka-flex  ${addClass}`}>
      <slot />
   </article>
</a>

<style lang="scss">
   a {
      // position: absolute;
      // top: 0;
      // left: 0;
      // width: 100%;
      // height: 100%;
      // background-color: purple
      text-decoration: none;

      a:visited {
         color: transparent;
      }
   }

   .oka-projet {
      position: relative;
      display: flex;
      justify-content: space-between;
      align-items: end;

      aspect-ratio: 4/3;
      margin-left: -1px;
      margin-bottom: -1px;
      padding: 0.5rem;

      border: 1px solid var(--oka-color-bd-strong);
      border-radius: .5rem;
      overflow: hidden;
      cursor: pointer;

      & > * {
         z-index: 99;
         pointer-events: none;
      }
   }
</style>