<style lang="scss">
  .-two {
    gap: 2rem
  }

  .sok-t-wrapper {
    display: flex;

    .sok-t-paragraph {
      width: 100%;
      max-width: 680px;
    }

    // Titre Hero
    &.-first {
      align-items: end;
    }

    // Paragraph Hero
    &.-second {
      justify-content: end;
    }

    // Paragraph projet
    &.-third,
    &.-fourth {
      align-items: end;
    }
  }

  // empêche le marquee de dépasser de la dernière section
  section:last-child {
    overflow: hidden;
  }
</style>