// ===== Transitions =====
import { ClientRouter } from "astro:transitions"; 
// ===== Components =====
import Header from "../components/commun/Header.astro";
import Footer from "../components/commun/Footer.astro";



import Appearup from '../animations/AppearUp.astro';
import Appeardown from '../animations/AppearDown.astro';
import Appeargroup from '../animations/AppearGroup.astro';
import FadeIn from '../animations/FadeIn.astro';
import Smoothscroll from '../animations/smoothscroll/Smoothscroll.astro';


interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = '/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- ===== HTML ===== -->
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description}>
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site)} />
		<meta property="og:locale" content="fr_FR" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.site)} />

		<!-- Fonts -->
		<link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/inter/InterVariable.woff2`} as="font" type="font/woff2" crossorigin>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<ClientRouter />
		

		<!-- <style lang="scss" is:global>
            @import '../styles/main.scss';
        </style> -->

	</head>
	<body>
		<div id="root" class="layout-app">

			<div class="sok-hero_ray" aria-hidden="true"></div>


			<Header />
			
			<main class="layout-app__main">
				<!-- Contenu principal -->
				<slot />
			</main>


			<slot name="Footer">
				<Footer />
			</slot>

			<!-- Grid Preview -->
			<div class="flex-grid-bg-fx z-index-1 " aria-hidden="true">
					<div class="oka-app-wrap -full" style="height:100%">
						<div class="grid-bg-fx__grid flex-grid ">
		
							<div class="col col-1"></div>
							<div class="col col-1"></div>
							<div class="col col-1" ></div>
							<div class="col col-1" ></div>
		
							<div class="col col-1"></div>
							<div class="col col-1"></div>
							<div class="col col-1" ></div>
							<div class="col col-1" ></div>
		
							<div class="col col-1"></div>
							<div class="col col-1"></div>
							<div class="col col-1" ></div>
							<div class="col col-1" ></div>
		
							<div class="col col-1"></div>
							<div class="col col-1"></div>
							<div class="col col-1" ></div>
							<div class="col col-1" ></div>
						</div>
					</div>
			</div>
		</div>
	</body>
</html>



