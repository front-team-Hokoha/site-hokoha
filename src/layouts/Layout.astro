---
// ===== TODO SEO =====
// TODO: Créer /public/og-image.jpg — image de partage réseaux sociaux (format recommandé : 1200×630px)

// ===== Transitions =====
import { ClientRouter } from "astro:transitions"; 

// ===== Components =====
import Header from "../components/commun/Header.astro";
import Footer from "../components/commun/Footer.astro";

// ===== Animations =====
import Appearup from '../animations/AppearUp.astro';
import Appeardown from '../animations/AppearDown.astro';
import Appeargroup from '../animations/AppearGroup.astro';
import FadeIn from '../animations/FadeIn.astro';
import Smoothscroll from '../animations/smoothscroll/Smoothscroll.astro';

// ===== Styles =====
import criticalCss from '../styles/oka-design-system/critical.scss?inline';
//import mainStylesUrl from '../styles/main.scss?url';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = '/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- ===== HTML ===== -->
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description}>
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site)} />
		<meta property="og:locale" content="fr_FR" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.site)} />

		<!-- Preload Fonts -->
		<link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/inter/InterVariable.woff2`} as="font" type="font/woff2" crossorigin>
		<link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/ibm-plex-sans-v8-latin/ibm-plex-sans-v8-latin-regular.woff2`} as="font" type="font/woff2" crossorigin>
		<link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/ibm-plex-sans-v8-latin/ibm-plex-sans-v8-latin-300.woff2`} as="font" type="font/woff2" crossorigin>
		<link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/ibm-plex-sans-v8-latin/ibm-plex-sans-v8-latin-600.woff2`} as="font" type="font/woff2" crossorigin>
		<link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/fontawesome-v7/fa-solid-900.woff2`} as="font" type="font/woff2" crossorigin>

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

		<!-- Critical CSS -->
		<style is:inline set:html={criticalCss}></style>

		<!-- CSS Non-Critique (chargé en priorité basse avec media="print") -->
		<!-- <link rel="stylesheet" href={mainStylesUrl} media="print" onload="this.onload=null;this.media='all'" /> -->

		<ClientRouter />
		
	</head>
	<body>
		<div id="root" class="layout-app">

			<Header />
			
			<main class="layout-app__main">
				<!-- Contenu principal -->
				<slot />
			</main>


			<slot name="Footer">
				<Footer />
			</slot>

			<!-- Grid Preview -->
			<div class="flex-grid-bg-fx z-index-1 " aria-hidden="true">
				<div class="oka-app-wrap -full" style="height:100%">
					<div class="grid-bg-fx__grid flex-grid ">
	
						<div class="col col-1"></div>
						<div class="col col-1"></div>
						<div class="col col-1" ></div>
						<div class="col col-1" ></div>
	
						<div class="col col-1"></div>
						<div class="col col-1"></div>
						<div class="col col-1" ></div>
						<div class="col col-1" ></div>
	
						<div class="col col-1"></div>
						<div class="col col-1"></div>
						<div class="col col-1" ></div>
						<div class="col col-1" ></div>
	
						<div class="col col-1"></div>
						<div class="col col-1"></div>
						<div class="col col-1" ></div>
						<div class="col col-1" ></div>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>



<!-- <LocalScripts /> -->
<Smoothscroll />
<Appearup />
<Appeardown />
<Appeargroup />
<FadeIn />




<script is:inline data-astro-rerun >
        
	/**
	* Get the value of a cookie
	* Source: https://gist.github.com/wpsmith/6cf23551dd140fb72ae7
	* @param  {String} name  The name of the cookie
	* @return {String}       The cookie value
	*/
	/*
	https://stackoverflow.com/questions/5671451/creating-a-javascript-cookie-on-a-domain-and-reading-it-across-sub-domains
	*/
	function getCookie (name) {
		let value = `; ${document.cookie}`;
		let parts = value.split(`; ${name}=`);
		if (parts.length === 2) return parts.pop().split(';').shift();
	}

	function applyShowGrid (){
		let showGrid =  getCookie('showGrid')
		if (showGrid=='true'){
			document.body.classList.add('showGrid');
		}else{
			document.body.classList.remove('showGrid');
		}
	}
		
	applyShowGrid();
</script>








<script  is:inline data-astro-rerun>
	// Interactions de clavier
	function KeyPress(e) {
		var evtobj = window.event? event : e;
		// TOGGLE 8pt GRID
		if (evtobj.keyCode == 223 && evtobj.ctrlKey) {
			document.body.classList.toggle('showGrid');
		}
		// Ferme tous les modals
		if (evtobj.keyCode == 27) {
			window.location.hash='';
		}
	}
	document.onkeydown = KeyPress;
</script>